<!-- Brand Point Premium Interactive Feature Cards -->
<section class="bp-feature-section">
  <div class="bp-feature-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.card_link | default: '#' }}" class="bp-feature-card" {{ block.shopify_attributes }}>
        <div class="bp-icon-wrapper">
          {%- if block.settings.custom_svg != blank -%}
            {{ block.settings.custom_svg }}
          {%- else -%}
            <span class="bp-fallback-icon">✦</span>
          {%- endif -%}
        </div>
        <div class="bp-text-wrapper">
          <h3 class="bp-card-title">{{ block.settings.title }}</h3>
          <p class="bp-card-subtitle">{{ block.settings.subtitle }}</p>
        </div>
        <div class="bp-card-arrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  .bp-feature-section {
    background: transparent;
    padding: 30px 15px;
    width: 100%;
    box-sizing: border-box;
  }
  .bp-feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .bp-feature-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03); 
    backdrop-filter: blur(12px) saturate(160%);
    -webkit-backdrop-filter: blur(12px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px; 
    padding: 18px 14px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    min-height: 115px;
    box-sizing: border-box;
  }
  .bp-feature-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-3px);
  }
  .bp-icon-wrapper { color: #ffffff; margin-bottom: 12px; display: flex; }
  .bp-icon-wrapper svg { width: 24px; height: 24px; }
  .bp-card-title { color: #ffffff; font-size: 11.5px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; margin: 0 0 4px 0; }
  .bp-card-subtitle { color: #b0b0b0; font-size: 10.5px; margin: 0; line-height: 1.3; }
  .bp-card-arrow { position: absolute; top: 15px; right: 15px; color: rgba(255, 255, 255, 0.25); }
  @media (min-width: 769px) {
    .bp-feature-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .bp-feature-section { padding: 50px 40px; }
  }
</style>

{% schema %}
{
  "name": "Brand Point Glass Cards",
  "settings": [],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "default": "SECURE PAYMENTS" },
        { "type": "text", "id": "subtitle", "label": "Sub-heading", "default": "256-bit SSL" },
        { "type": "html", "id": "custom_svg", "label": "SVG Icon Code" },
        { "type": "url", "id": "card_link", "label": "Link Target (Footer Page)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Point Glass Cards",
      "blocks": [
        { "type": "feature_card", "settings": { "title": "SECURE PAYMENTS", "subtitle": "256-bit SSL" } },
        { "type": "feature_card", "settings": { "title": "EASY RETURNS", "subtitle": "7-day policy" } },
        { "type": "feature_card", "settings": { "title": "PREMIUM QUALITY", "subtitle": "Certified fabrics" } },
        { "type": "feature_card", "settings": { "title": "FAST SHIPPING", "subtitle": "2-4 business days" } },
        { "type": "feature_card", "settings": { "title": "24/7 SUPPORT", "subtitle": "WhatsApp & chat" } },
        { "type": "feature_card", "settings": { "title": "BEST PRICES", "subtitle": "Lowest guaranteed" } }
      ]
    }
  ]
}
{% endschema %}
