<!-- ========================================================== -->
<!--     BRAND POINT ULTRA-LUXURY PRESTIGE HEADER ARCHITECTURE  -->
<!-- ========================================================== -->

<header class="bp-elite-header-wrapper">
  <div class="bp-header-container">
    
    <!-- LEFT: HAMBURGER MENU (SILK DRAWER TRIGGER) -->
    <div class="bp-header-item bp-header-left">
      <button type="button" class="bp-icon-btn bp-menu-toggle" aria-label="Open Menu" id="bpMenuOpenBtn">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- CENTER: LOGO WITH METALLIC PLATINUM LIQUID SHINE (STRICTLY ONE LINE) -->
    <div class="bp-header-item bp-header-center">
      <a href="/" class="bp-site-logo-prestige">
        <span class="bp-logo-text-shine">BRAND POINT</span>
      </a>
    </div>

    <!-- RIGHT: ICONS (PREDICTIVE SEARCH, USER PORTAL, ANIMATED CART) -->
    <div class="bp-header-item bp-header-right">
      
      <!-- Smart Search Trigger -->
      <button type="button" class="bp-icon-btn" aria-label="Search" id="bpSearchOpenBtn">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>

      <!-- Account / Portal -->
      <a href="/account" class="bp-icon-btn" aria-label="Account Portal">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>

      <!-- Micro-Animated Cart -->
      <a href="/cart" class="bp-icon-btn bp-cart-icon-wrapper" id="bpCartIcon">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="bp-badge-count" id="bpCartCount">{% if cart.item_count %}{{ cart.item_count }}{% else %}0{% endif %}</span>
      </a>

    </div>
  </div>
</header>

<!-- ========================================== -->
<!--   MODULE A: SILK OVERLAY CATEGORY DRAWER   -->
<!-- ========================================== -->
<div class="bp-silk-drawer-overlay" id="bpMenuOverlay"></div>
<aside class="bp-silk-menu-drawer" id="bpMenuDrawer">
  <div class="bp-drawer-header">
    <span class="bp-drawer-title">NAVIGATION</span>
    <button type="button" class="bp-drawer-close-btn" id="bpMenuCloseBtn">✕</button>
  </div>
  
  <div class="bp-drawer-account-portal">
    <a href="/account/login" class="bp-drawer-auth-btn">SIGN IN / CREATE ACCOUNT</a>
  </div>

  <nav class="bp-drawer-nav-links">
    <a href="/collections/shirts" class="bp-nav-item-link">👕 SHIRTS</a>
    <a href="/collections/denim" class="bp-nav-item-link">👖 DENIM</a>
    <a href="/collections/t-shirts" class="bp-nav-item-link">🥼 T-SHIRTS</a>
    <a href="/collections/accessories" class="bp-nav-item-link">🕶️ ACCESSORIES</a>
    <a href="/collections/track" class="bp-nav-item-link">🏃 TRACK</a>
    <a href="/collections/cord-set" class="bp-nav-item-link">🧥 CO-RD SET</a>
  </nav>

  <div class="bp-drawer-footer-trust">
    <a href="/pages/reviews" class="bp-drawer-reviews-link">
      <span class="bp-stars">★★★★★</span>
      <span class="bp-review-txt">CUSTOMER REVIEWS</span>
    </a>
  </div>
</aside>

<!-- ========================================== -->
<!--   MODULE B: GLASSMORPHISM MIRROR SEARCH    -->
<!-- ========================================== -->
<div class="bp-search-overlay-fullscreen" id="bpSearchOverlay">
  <div class="bp-search-overlay-container">
    <div class="bp-search-top-bar">
      <span class="bp-search-modal-title">PRESTIGE SEARCH</span>
      <button type="button" class="bp-search-close-btn" id="bpSearchCloseBtn">✕</button>
    </div>
    
    <!-- 🎯 यहाँ बदलाव किया गया है: अब हेडर जैसा सेम सर्च आइकॉन अंदर भी आ गया है -->
    <form action="/search" method="get" role="search" class="bp-search-input-field-row">
      <div style="position: relative; display: flex; align-items: center; width: 100%;">
        <input 
          type="search" 
          name="q"
          autocomplete="off" 
          placeholder="SEARCH FOR SHIRTS, DENIM, CORSET..." 
          class="bp-smart-search-input" 
          id="bpSearchInputField"
          value="{{ search.terms | escape }}"
          style="padding-right: 40px;"
        >
        <button type="submit" aria-label="Submit Search" style="background: none; border: none; color: #ffffff; cursor: pointer; position: absolute; right: 0; padding: 8px; display: flex; align-items: center; justify-content: center;">
          <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </div>
      <span class="bp-search-input-underline"></span>
    </form>

    <div class="bp-search-predictions-container" id="bpSearchPredictions">
      <div class="bp-search-static-suggestions" id="bpStaticSuggestions">
        <p class="bp-suggestion-heading">SUGGESTED CATEGORIES</p>
        <div class="bp-suggestion-tags">
          <a href="/collections/shirts">SHIRTS</a>
          <a href="/collections/denim">DENIM</a>
          <a href="/collections/cord-set">CO-ORD SET</a>
        </div>
      </div>
      <div class="bp-dynamic-results-grid" id="bpDynamicResultsGrid"></div>
    </div>
  </div>
</div>

<!-- ========================================== -->
<!--     PRESTIGE STYLING ARCHITECTURE (CSS)    -->
<!-- ========================================== -->
<style>
  .bp-elite-header-wrapper {
    background-color: #000000;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    height: 70px;
    display: flex;
    align-items: center;
  }
  .bp-header-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .bp-header-item {
    display: flex;
    align-items: center;
  }
  .bp-header-center {
    flex-grow: 1;
    justify-content: center;
    max-width: 50%;
  }
  .bp-icon-btn {
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 8px;
    margin-right: 4px;
    position: relative;
    transition: transform 0.2s ease;
  }
  .bp-icon-btn:hover {
    transform: scale(1.05);
  }

  /* Fixed Logo - Strictly One Single Horizontal Line */
  .bp-site-logo-prestige {
    text-decoration: none;
    display: block;
    white-space: nowrap; /* Prevents text from breaking into two lines */
    text-align: center;
  }
  .bp-logo-text-shine {
    font-size: 20px;
    font-weight: 900;
    letter-spacing: 4px;
    color: #ffffff;
    position: relative;
    text-transform: uppercase;
    background: linear-gradient(to right, #ffffff 20%, #a6a6a6 40%, #ffffff 60%, #ffffff 80%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: platinumShine 4s linear infinite;
  }
  @keyframes platinumShine {
    0% { background-position: 200% center; }
    100% { background-position: 0% center; }
  }

  .bp-badge-count {
    position: absolute;
    top: 0;
    right: 0;
    background-color: #ffffff;
    color: #000000;
    font-size: 9px;
    font-weight: 800;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bp-cart-pulse-active {
    animation: cartMicroPulse 0.45s cubic-bezier(0.25, 1, 0.5, 1);
  }
  @keyframes cartMicroPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.25); }
    100% { transform: scale(1); }
  }

  /* Silk Drawer Settings */
  .bp-silk-drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  .bp-silk-drawer-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .bp-silk-menu-drawer {
    position: fixed;
    top: 0;
    left: -320px;
    width: 320px;
    height: 100vh;
    background-color: #0a0a0a;
    z-index: 2001;
    box-shadow: 10px 0 30px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .bp-silk-menu-drawer.active {
    left: 0;
  }
  .bp-drawer-header {
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .bp-drawer-title {
    color: #888888;
    font-size: 11px;
    letter-spacing: 2px;
    font-weight: 700;
  }
  .bp-drawer-close-btn, .bp-search-close-btn {
    background: none;
    border: none;
    color: #ffffff;
    font-size: 18px;
    cursor: pointer;
  }
  .bp-drawer-account-portal {
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .bp-drawer-auth-btn {
    display: block;
    text-align: center;
    background: #ffffff;
    color: #000000;
    text-decoration: none;
    font-size: 11px;
    font-weight: 700;
    padding: 12px;
    letter-spacing: 1px;
  }
  .bp-drawer-nav-links {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex-grow: 1;
  }
  .bp-nav-item-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1.5px;
    transition: padding-left 0.2s ease;
  }
  .bp-nav-item-link:hover {
    padding-left: 6px;
    color: #cccccc;
  }
  .bp-drawer-footer-trust {
    padding: 24px;
    border-top: 1px solid rgba(255,255,255,0.05);
    text-align: center;
  }
  .bp-drawer-reviews-link {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .bp-stars { color: #fff; font-size: 14px; letter-spacing: 2px; }
  .bp-review-txt { color: #888; font-size: 10px; font-weight: 700; letter-spacing: 1px;}

  /* Premium Glassmorphic Mirror Search Interface */
  .bp-search-overlay-fullscreen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(10, 10, 10, 0.45); /* High-end translucent background */
    backdrop-filter: blur(20px); /* Pure Mirror/Glass effect for background elements */
    -webkit-backdrop-filter: blur(20px);
    z-index: 3000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    display: flex;
    justify-content: center;
  }
  .bp-search-overlay-fullscreen.active {
    opacity: 1;
    pointer-events: auto;
  }
  .bp-search-overlay-container {
    width: 100%;
    max-width: 700px;
    padding: 40px 24px;
  }
  .bp-search-top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }
  .bp-search-modal-title {
    color: #ffffff;
    font-size: 11px;
    letter-spacing: 3px;
    font-weight: 700;
    opacity: 0.6;
  }
  .bp-search-input-field-row {
    position: relative;
    width: 100%;
    margin-bottom: 30px;
    display: block;
  }
  .bp-smart-search-input {
    width: 100%;
    background: transparent;
    border: none;
    color: #ffffff;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 2px;
    padding: 12px 0;
    outline: none;
  }
  .bp-search-input-underline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(255,255,255,0.25);
  }
  .bp-suggestion-heading {
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin-bottom: 15px;
    opacity: 0.5;
  }
  .bp-suggestion-tags a {
    display: inline-block;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.05);
    padding: 8px 18px;
    font-size: 11px;
    font-weight: 600;
    text-decoration: none;
    margin-right: 10px;
    letter-spacing: 1px;
    backdrop-filter: blur(5px);
  }
  
  .bp-dynamic-results-grid {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    max-height: 50vh;
    overflow-y: auto;
  }
  .bp-search-live-item {
    display: flex;
    align-items: center;
    gap: 15px;
    text-decoration: none;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .bp-search-live-item img {
    width: 50px;
    height: 60px;
    object-fit: cover;
  }
  .bp-search-live-title {
    color: #fff;
    font-size: 13px;
    font-weight: 600;
  }
  .bp-search-live-price {
    color: #ccc;
    font-size: 12px;
    margin-top: 2px;
  }

  /* Responsive fixes for mobile logo sizing */
  @media (max-width: 768px) {
    .bp-logo-text-shine {
      font-size: 16px;
      letter-spacing: 3px;
    }
  }
</style>

<!-- ========================================== -->
<!--    PRESTIGE LOGIC CORE ENGINE (JAVASCRIPT)  -->
<!-- ========================================== -->
<script>
document.addEventListener("DOMContentLoaded", function() {
  
  const menuOpenBtn = document.getElementById("bpMenuOpenBtn");
  const menuCloseBtn = document.getElementById("bpMenuCloseBtn");
  const menuDrawer = document.getElementById("bpMenuDrawer");
  const menuOverlay = document.getElementById("bpMenuOverlay");

  const searchOpenBtn = document.getElementById("bpSearchOpenBtn");
  const searchCloseBtn = document.getElementById("bpSearchCloseBtn");
  const searchOverlay = document.getElementById("bpSearchOverlay");
  const searchInput = document.getElementById("bpSearchInputField");
  const dynamicResults = document.getElementById("bpDynamicResultsGrid");
  const staticSuggestions = document.getElementById("bpStaticSuggestions");

  if(menuOpenBtn && menuDrawer && menuOverlay) {
    menuOpenBtn.addEventListener("click", () => {
      menuDrawer.classList.add("active");
      menuOverlay.classList.add("active");
    });
  }
  if(menuCloseBtn && menuDrawer && menuOverlay) {
    menuCloseBtn.addEventListener("click", () => {
      menuDrawer.classList.remove("active");
      menuOverlay.classList.remove("active");
    });
    menuOverlay.addEventListener("click", () => {
      menuDrawer.classList.remove("active");
      menuOverlay.classList.remove("active");
    });
  }

  if(searchOpenBtn && searchOverlay) {
    searchOpenBtn.addEventListener("click", () => {
      searchOverlay.classList.add("active");
      setTimeout(() => searchInput.focus(), 100);
    });
  }
  if(searchCloseBtn && searchOverlay) {
    searchCloseBtn.addEventListener("click", () => {
      searchOverlay.classList.remove("active");
    });
  }

  if(searchInput) {
    searchInput.addEventListener("input", function(e) {
      const query = e.target.value.trim();
      if(query.length > 1) {
        staticSuggestions.style.display = "none";
        
        fetch(`/search/suggest.json?q=${query}&resources[type]=product&resources[limit]=4`)
        .then(response => response.json())
        .then(suggestions => {
          const products = suggestions.resources.results.products;
          dynamicResults.innerHTML = "";
          
          if(products.length > 0) {
            products.forEach(product => {
              dynamicResults.innerHTML += `
                <a href="${product.url}" class="bp-search-live-item">
                  <img src="${product.image}" alt="${product.title}">
                  <div>
                    <div class="bp-search-live-title">${product.title.toUpperCase()}</div>
                    <div class="bp-search-live-price">₹${product.price}</div>
                  </div>
                </a>
              `;
            });
          } else {
            dynamicResults.innerHTML = `<p style="color:#888;font-size:12px;letter-spacing:1px;">NO PRODUCTS FOUND</p>`;
          }
        });
      } else {
        staticSuggestions.style.display = "block";
        dynamicResults.innerHTML = "";
      }
    });
  }

  window.triggerBrandPointCartPulse = function() {
    const cartIcon = document.getElementById("bpCartIcon");
    if(cartIcon) {
      cartIcon.classList.add("bp-cart-pulse-active");
      setTimeout(() => {
        cartIcon.classList.remove("bp-cart-pulse-active");
      }, 450);
    }
  };

  const nativeFetch = window.fetch;
  window.fetch = function(...args) {
    return nativeFetch.apply(this, args).then(response => {
      if (args[0] && args[0].includes('/cart/add')) {
        window.triggerBrandPointCartPulse();
      }
      return response;
    });
  };
});
</script>

{% schema %}
{
  "name": "Elite Luxury Header",
  "settings": []
}
{% endschema %}
