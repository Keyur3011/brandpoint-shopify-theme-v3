<!-- Trust Badges Section -->
<div class="trust-badges-section">
  <div class="badges-container">
    
    <!-- Badge 1: Secure Payments -->
    <div class="badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </div>
      <h3 class="badge-title">SECURE PAYMENTS</h3>
      <p class="badge-subtitle">256-bit SSL</p>
    </div>

    <!-- Badge 2: Easy Returns -->
    <div class="badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
      </div>
      <h3 class="badge-title">EASY RETURNS</h3>
      <p class="badge-subtitle">7-day policy</p>
    </div>

    <!-- Badge 3: Premium Quality -->
    <div class="badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
      </div>
      <h3 class="badge-title">PREMIUM QUALITY</h3>
      <p class="badge-subtitle">Certified fabrics</p>
    </div>

    <!-- Badge 4: Fast Shipping -->
    <div class="badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
      </div>
      <h3 class="badge-title">FAST SHIPPING</h3>
      <p class="badge-subtitle">2-4 business days</p>
    </div>

    <!-- Badge 5: 24/7 Support -->
    <div class="badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
      </div>
      <h3 class="badge-title">24/7 SUPPORT</h3>
      <p class="badge-subtitle">WhatsApp & chat</p>
    </div>

    <!-- Badge 6: Best Prices -->
    <div class="badge-item">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
      </div>
      <h3 class="badge-title">BEST PRICES</h3>
      <p class="badge-subtitle">Lowest guaranteed</p>
    </div>

  </div>
</div>

<style>
  .trust-badges-section {
    background-color: #ffffff; /* Contrast white background as per figma design */
    color: #000000;
    padding: 40px 15px;
    border-top: 1px solid #eeeeee;
    border-bottom: 1px solid #eeeeee;
  }

  .badges-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 2 columns on small screens, adjusts cleanly */
    gap: 30px 15px;
    text-align: center;
  }

  .badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .badge-icon {
    color: #000000;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin: 0 0 4px 0;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  .badge-subtitle {
    font-size: 9px;
    color: #666666;
    margin: 0;
    letter-spacing: 0.5px;
    font-weight: 400;
  }

  /* Responsive breakpoints for clean layout */
  @media (min-width: 480px) {
    .badges-container {
      grid-template-columns: repeat(3, 1fr); /* 3 columns on slightly larger phones/tablets */
    }
  }

  @media (min-width: 992px) {
    .trust-badges-section {
      padding: 50px 40px;
    }
    .badges-container {
      grid-template-columns: repeat(6, 1fr); /* All 6 in one line on desktop */
      gap: 20px;
    }
    .badge-title {
      font-size: 11px;
    }
    .badge-subtitle {
      font-size: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Badges",
  "settings": []
}
{% endschema %}
