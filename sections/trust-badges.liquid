<!-- ========================================== -->
<!--     HIGH-END PROFESSIONAL BLUR STYLING     -->
<!-- ========================================== -->
<style>
  .bp-modal-badges-section {
    background-color: #030303; /* Deep Matte Jet Black */
    padding: 60px 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .bp-modal-grid-container {
    width: 100%;
    max-width: 850px;
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Clean 2-Column Layout */
    gap: 24px;
  }

  /* Real Glass Button Architecture */
  .bp-modal-card-btn {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 18px;
    cursor: pointer;
    text-align: left;
    outline: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    width: 100%;
  }

  .bp-modal-card-btn:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.03);
  }

  .bp-modal-icon-wrapper svg {
    width: 28px;
    height: 28px;
    color: rgba(255, 255, 255, 0.85);
    display: block;
  }

  .bp-modal-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .bp-modal-title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #ffffff;
    text-transform: uppercase;
  }

  .bp-modal-sub {
    margin: 0;
    font-size: 11px;
    font-weight: 400;
    color: #777777;
    letter-spacing: 0.5px;
  }

  /* ========================================== -->
  <!--       ULTRA FANCY POPUP MODAL (THE BLUR)   -->
  <!-- ========================================== */
  .bp-custom-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6); 
    backdrop-filter: blur(12px); 
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 20px;
    box-sizing: border-box; /* Fixed sizing bug */
  }

  .bp-custom-modal.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Fixed Mobile Width Shift */
  .bp-modal-popup-box {
    background: rgba(18, 18, 18, 0.85); 
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 18px;
    max-width: 450px;
    width: 100%;
    box-sizing: border-box; /* Forces box to stay within screen boundaries */
    padding: 32px;
    position: relative;
    transform: scale(0.92);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
  }

  .bp-custom-modal.is-active .bp-modal-popup-box {
    transform: scale(1);
  }

  .bp-modal-close-btn {
    position: absolute;
    top: 18px;
    right: 18px;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 14px;
    cursor: pointer;
    transition: color 0.2s ease;
    outline: none;
  }

  .bp-modal-close-btn:hover {
    color: #ffffff;
  }

  .bp-modal-popup-title {
    margin: 0 0 14px 0;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 2px;
    color: #ffffff;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 10px;
  }

  .bp-modal-popup-text {
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
    color: #cccccc; 
    letter-spacing: 0.3px;
  }

  /* Mobile Grid & Modal Alignment Fix */
  @media (max-width: 768px) {
    .bp-modal-grid-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .bp-modal-card-btn {
      padding: 20px 12px;
      flex-direction: column;
      text-align: center;
      gap: 10px;
    }
    .bp-modal-title {
      font-size: 11px;
      letter-spacing: 1px;
    }
    .bp-modal-sub {
      font-size: 9px;
    }
    .bp-modal-popup-box {
      padding: 24px 20px;
      width: calc(100% - 10px); /* Keeps strict uniform padding on screen borders */
      margin: 0 auto;
    }
  }
</style>

<!-- ========================================== -->
<!--       ULTRA LIGHT POPUP ENGINE (JS)        -->
<!-- ========================================== -->
<script>
function openBpBadgeModal(modalId) {
  const modal = document.getElementById(modalId);
  if (modal) {
    modal.classList.add('is-active');
    document.body.style.overflow = 'hidden'; 
  }
}

function closeBpBadgeModal(modalId) {
  const modal = document.getElementById(modalId);
  if (modal) {
    modal.classList.remove('is-active');
    document.body.style.overflow = ''; 
  }
}

function closeBpBadgeModalOutside(event, modalElement) {
  if (event.target === modalElement) {
    modalElement.classList.remove('is-active');
    document.body.style.overflow = '';
  }
}
</script>

