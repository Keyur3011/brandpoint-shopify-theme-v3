<!-- ========================================== -->
<!--        PRESTIGE GOLDEN GLASS STYLING        -->
<!-- ========================================== -->
<style>
  .bp-trust-badges-section {
    background-color: #050505; /* Deep Ultra Matte Black */
    padding: 60px 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .bp-badges-container {
    width: 100%;
    max-width: 800px;
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Strict 2-Column Grid Layout */
    gap: 20px;
  }

  /* Real Glassmorphism Button Card Sizing */
  .bp-badge-card {
    background: rgba(255, 255, 255, 0.03); /* Translucent Glass Blend */
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(212, 175, 55, 0.2); /* Thin Subtle Metallic Gold Border */
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
  }

  /* Liquid Gold Glow & Micro-movement on Hover/Touch */
  .bp-badge-card:hover {
    transform: translateY(-4px) scale(1.02);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(212, 175, 55, 0.8); /* Glow intensifies to Premium Gold */
    box-shadow: 0 0 25px rgba(212, 175, 55, 0.25); /* Liquid Gold Aura Backlight */
  }

  /* Icons Styling with Golden Tint */
  .bp-badge-icon-wrapper svg {
    width: 32px;
    height: 32px;
    color: #d4af37; /* Metallic Pure Gold Color */
    display: block;
    transition: transform 0.3s ease;
  }

  .bp-badge-card:hover .bp-badge-icon-wrapper svg {
    transform: rotate(-5deg) scale(1.1);
  }

  .bp-badge-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Title - High Luxury Gold Gradient */
  .bp-badge-title {
    margin: 0;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 2px;
    color: #d4af37; /* Pure Gold */
    background: linear-gradient(135deg, #ffe596 0%, #d4af37 50%, #9a7413 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-transform: uppercase;
  }

  /* Subtext - Sleek Subtle Gray */
  .bp-badge-sub {
    margin: 0;
    font-size: 11px;
    font-weight: 500;
    color: #888888;
    letter-spacing: 0.5px;
  }

  /* Mobile Responsive - Keeps it perfectly 2 columns even on small screens */
  @media (max-width: 600px) {
    .bp-badges-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .bp-badge-card {
      padding: 16px 12px;
      flex-direction: column;
      text-align: center;
      gap: 10px;
    }
    .bp-badge-title {
      font-size: 11px;
      letter-spacing: 1px;
    }
    .bp-badge-sub {
      font-size: 9px;
    }
    .bp-badge-icon-wrapper svg {
      width: 26px;
      height: 26px;
    }
  }
</style>

