<!-- ========================================== -->
<!--     ULTRA REALISTIC RICH GLASS STYLING      -->
<!-- ========================================== -->
<style>
  .bp-rich-badges-section {
    background-color: #030303; /* Pure Luxury Jet Black */
    padding: 60px 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: inherit;
  }

  .bp-rich-container {
    width: 100%;
    max-width: 850px;
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Clean 2-Column Desktop & Mobile Architecture */
    gap: 24px;
  }

  .bp-rich-card-wrapper {
    background: rgba(255, 255, 255, 0.02); /* High-End Translucent Sheet */
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.05); /* Platinum/Silver Smoke Thin Border */
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Rich Metallic Subtle White-Glow on Hover */
  .bp-rich-card-wrapper:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow: 0 0 35px rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  /* Trigger Button Structure */
  .bp-rich-card-btn {
    width: 100%;
    background: none;
    border: none;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    cursor: pointer;
    text-align: left;
    outline: none;
    position: relative;
  }

  /* Icons Styling - Platinum Chrome White Color */
  .bp-rich-icon-wrapper svg {
    width: 28px;
    height: 28px;
    color: rgba(255, 255, 255, 0.85); /* Rich Matte White */
    display: block;
    transition: transform 0.3s ease;
  }

  .bp-rich-card-wrapper:hover .bp-rich-icon-wrapper svg {
    transform: scale(1.08);
  }

  .bp-rich-content {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex-grow: 1;
  }

  /* Title - Clean Professional Platinum White */
  .bp-rich-title {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #ffffff;
    text-transform: uppercase;
  }

  /* Subtext - Deep Smoked Steel Gray */
  .bp-rich-sub {
    margin: 0;
    font-size: 11px;
    font-weight: 400;
    color: #777777;
    letter-spacing: 0.5px;
  }

  /* Minimalist Interactive Indicator */
  .bp-rich-arrow {
    color: rgba(255, 255, 255, 0.25);
    font-size: 10px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transform: rotate(-45deg); /* Professional Plus/Cross Style look */
  }

  /* Open State Styles */
  .bp-rich-card-wrapper.is-open {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .bp-rich-card-wrapper.is-open .bp-rich-arrow {
    transform: rotate(0deg);
    color: #ffffff;
  }

  /* Smooth Accordion Panel Content Logic */
  .bp-rich-detail-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    background: rgba(0, 0, 0, 0.2);
  }

  .bp-rich-detail-inner {
    padding: 0 24px 24px 24px;
    font-size: 12px;
    line-height: 1.6;
    color: #b0b0b0; /* Extremely clean readable gray text */
    letter-spacing: 0.3px;
  }

  .bp-rich-detail-inner p {
    margin: 0;
  }

  /* Mobile Layout - Keeps exactly 2-columns but trims space cleanly */
  @media (max-width: 768px) {
    .bp-rich-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .bp-rich-card-btn {
      padding: 18px 12px;
      flex-direction: column;
      text-align: center;
      gap: 12px;
    }
    .bp-rich-arrow {
      position: absolute;
      top: 12px;
      right: 12px;
    }
    .bp-rich-title {
      font-size: 11px;
      letter-spacing: 1px;
    }
    .bp-rich-sub {
      font-size: 9px;
    }
    .bp-rich-detail-inner {
      padding: 0 12px 16px 12px;
      font-size: 11px;
      text-align: left;
    }
  }
</style>

<!-- ========================================== -->
<!--     PRESTIGE SMOOTH ACCORDION ENGINE       -->
<!-- ========================================== -->
<script>
function toggleRichBadgeDetail(button) {
  const wrapper = button.closest('.bp-rich-card-wrapper');
  const panel = wrapper.querySelector('.bp-rich-detail-panel');
  const isExpanded = button.getAttribute('aria-expanded') === 'true';
  
  // Close all other opened panels first for a clean corporate flow
  document.querySelectorAll('.bp-rich-card-wrapper').forEach(item => {
    if (item !== wrapper && item.classList.contains('is-open')) {
      item.classList.remove('is-open');
      item.querySelector('.bp-rich-card-btn').setAttribute('aria-expanded', 'false');
      item.querySelector('.bp-rich-detail-panel').style.maxHeight = null;
    }
  });

  // Toggle the clicked panel smoothly
  if (isExpanded) {
    button.setAttribute('aria-expanded', 'false');
    wrapper.classList.remove('is-open');
    panel.style.maxHeight = null;
  } else {
    button.setAttribute('aria-expanded', 'true');
    wrapper.classList.add('is-open');
    panel.style.maxHeight = panel.scrollHeight + "px";
  }
}
</script>

