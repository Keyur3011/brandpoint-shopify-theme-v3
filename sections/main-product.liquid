<!-- Premium Figma-to-Shopify Product Page Structure -->
<div class="premium-product-wrapper">
  <div class="premium-product-container">
    
    <!-- Left: Media Gallery -->
    <div class="product-media-gallery">
      <div class="main-image-holder">
        {% if product.featured_image %}
          <img id="MainProductImage" src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}">
        {% else %}
          <img src="https://images.unsplash.com/photo-1618886614638-80e3c103d31a?auto=format&fit=crop&q=80&w=800" alt="Placeholder">
        {% endif %}
      </div>
      
      {% if product.images.size > 1 %}
        <div class="product-thumbnails-grid">
          {% for image in product.images %}
            <div class="thumb-image-card {% if forloop.first %}active-thumb{% endif %}" onclick="switchProductImage('{{ image | img_url: 'master' }}', this)">
              <img src="{{ image | img_url: '200x200', crop: 'center' }}" alt="Thumbnail">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Right: Product Information Panel -->
    <div class="product-info-panel">
      <h1 class="brand-product-title">{{ product.title }}</h1>
      
      <div class="brand-price-container">
        <span class="current-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="compare-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% form 'product', product, id: 'PremiumProductForm' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <!-- Options Selector (Color & Size) -->
        <div class="product-variants-selectors">
          {% for option in product.options_with_values %}
            <div class="variant-option-group">
              <label class="variant-label">{{ option.name | upcase }}:</label>
              <div class="variant-values-list">
                {% for value in option.values %}
                  {% assign is_color = false %}
                  {% assign option_name_lower = option.name | downcase %}
                  {% if option_name_lower contains 'color' or option_name_lower contains 'colour' %}
                    {% assign is_color = true %}
                  {% endif %}

                  {% if is_color %}
                    <!-- Round Color Swatches -->
                    <span class="color-swatch-circle" style="background-color: {{ value | downcase }};" title="{{ value }}"></span>
                  {% else %}
                    <!-- Box Size Swatches -->
                    <span class="size-swatch-box">{{ value }}</span>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>

        <!-- Quantity Counter -->
        <div class="quantity-selector-wrapper">
          <label class="variant-label">QUANTITY</label>
          <div class="quantity-input-box">
            <button type="button" onclick="changeQty(-1)">-</button>
            <input type="number" id="ProductQtyInput" name="quantity" value="1" min="1">
            <button type="button" onclick="changeQty(1)">+</button>
          </div>
        </div>

        <!-- Master Action Buttons -->
        <div class="action-buttons-stack">
          <button type="submit" class="btn-add-to-bag">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            ADD TO CART
          </button>
          <button type="button" class="btn-buy-now" onclick="triggerDirectCheckout()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
            BUY NOW
          </button>
        </div>
      {% endform %}

      <!-- WhatsApp Order Bridge -->
      <a href="https://wa.me/YOUR_NUMBER" target="_blank" class="whatsapp-order-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397 0 11.948 0c3.174.001 6.161 1.24 8.413 3.488 2.253 2.248 3.492 5.232 3.492 8.406-.003 6.549-5.34 11.897-11.891 11.897-2.006-.002-3.973-.508-5.714-1.472L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.755 1.451 5.352 0 9.713-4.346 9.716-9.693.001-2.59-1.006-5.025-2.834-6.855C16.404 2.228 13.976 1 11.95 1 6.599 1 2.239 5.348 2.236 10.697c-.001 1.637.452 3.232 1.311 4.647L2.518 20.9l5.69-1.492c-.22.1-.21.09-.56-.154z"/></svg>
        ORDER ON WHATSAPP
      </a>

      <!-- Trust Pillars Grid -->
      <div class="trust-pillars-grid">
        <div class="pillar-card">
          <span class="pillar-icon">🔒</span>
          <div>
            <h4>Secure Payment</h4>
            <p>100% safe checkout</p>
          </div>
        </div>
        <div class="pillar-card">
          <span class="pillar-icon">🔄</span>
          <div>
            <h4>Easy Returns</h4>
            <p>7-day return policy</p>
          </div>
        </div>
        <div class="pillar-card">
          <span class="pillar-icon">✨</span>
          <div>
            <h4>Premium Quality</h4>
            <p>Luxury craftsmanship</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .premium-product-wrapper { background-color: #000000; color: #ffffff; padding: 40px 15px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .premium-product-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 40px; }
  
  /* Media Gallery */
  .main-image-holder { width: 100%; aspect-ratio: 3/4; border-radius: 12px; overflow: hidden; background-color: #111; }
  .main-image-holder img { width: 100%; height: 100%; object-fit: cover; }
  .product-thumbnails-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-top: 15px; }
  .thumb-image-card { aspect-ratio: 1/1; border-radius: 6px; overflow: hidden; border: 1px solid #222; cursor: pointer; }
  .thumb-image-card img { width: 100%; height: 100%; object-fit: cover; }
  .active-thumb { border-color: #ffffff; }

  /* Info Panel */
  .brand-product-title { font-size: 26px; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 10px; }
  .brand-price-container { margin-bottom: 25px; display: flex; align-items: center; gap: 12px; }
  .current-price { font-size: 22px; font-weight: 700; }
  .compare-price { font-size: 16px; color: #666; text-decoration: line-through; }

  /* Swatches */
  .variant-option-group { margin-bottom: 20px; }
  .variant-label { display: block; font-size: 12px; font-weight: 600; color: #888; letter-spacing: 1px; margin-bottom: 10px; }
  .variant-values-list { display: flex; gap: 12px; align-items: center; }
  
  .color-swatch-circle { width: 28px; height: 28px; border-radius: 50%; display: inline-block; border: 2px solid #222; cursor: pointer; transition: 0.2s; }
  .color-swatch-circle:hover { transform: scale(1.1); border-color: #fff; }
  
  .size-swatch-box { padding: 8px 16px; border: 1px solid #333; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; transition: 0.2s; }
  .size-swatch-box:hover { border-color: #fff; background-color: #111; }

  /* Qty Counter */
  .quantity-selector-wrapper { margin-bottom: 30px; }
  .quantity-input-box { display: flex; align-items: center; width: 120px; border: 1px solid #333; border-radius: 6px; height: 40px; }
  .quantity-input-box button { width: 40px; height: 100%; background: none; border: none; color: #fff; font-size: 18px; cursor: pointer; }
  .quantity-input-box input { width: 40px; text-align: center; background: none; border: none; color: #fff; font-size: 14px; -appearance: textfield; }

  /* Action Buttons */
  .action-buttons-stack { display: flex; flex-direction: column; gap: 12px; margin-bottom: 15px; }
  .btn-add-to-bag, .btn-buy-now { width: 100%; height: 52px; font-weight: 700; font-size: 14px; letter-spacing: 1px; border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 10px; cursor: pointer; transition: 0.2s; }
  
  .btn-add-to-bag { background-color: #ffffff; color: #000000; border: none; }
  .btn-add-to-bag:hover { background-color: #eeeeee; }
  
  .btn-buy-now { background-color: #000000; color: #ffffff; border: 1px solid #ffffff; }
  .btn-buy-now:hover { background-color: #111111; }

  /* WhatsApp & Badges */
  .whatsapp-order-btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; height: 52px; border: 1px solid #075E54; border-radius: 8px; color: #25D366; text-decoration: none; font-weight: 700; font-size: 14px; margin-bottom: 30px; }
  
  .trust-pillars-grid { display: grid; grid-template-columns: 1fr; gap: 15px; border-top: 1px solid #222; padding-top: 25px; }
  .pillar-card { background-color: #0a0a0a; border: 1px solid #111; border-radius: 8px; padding: 15px; display: flex; align-items: center; gap: 15px; }
  .pillar-icon { font-size: 20px; }
  .pillar-card h4 { font-size: 14px; font-weight: 600; margin: 0 0 2px 0; }
  .pillar-card p { font-size: 12px; color: #666; margin: 0; }

  @media (min-width: 768px) {
    .premium-product-container { grid-template-columns: 1.1fr 0.9fr; gap: 60px; }
    .trust-pillars-grid { grid-template-columns: repeat(3, 1fr); }
    .action-buttons-stack { flex-direction: row; }
  }
</style>

<script>
  function switchProductImage(imgUrl, element) {
    document.getElementById('MainProductImage').src = imgUrl;
    document.querySelectorAll('.thumb-image-card').forEach(thumb => thumb.classList.remove('active-thumb'));
    element.classList.add('active-thumb');
  }
  function changeQty(amount) {
    var input = document.getElementById('ProductQtyInput');
    var current = parseInt(input.value);
    if(current + amount >= 1) { input.value = current + amount; }
  }
  function triggerDirectCheckout() {
    var form = document.getElementById('PremiumProductForm');
    var input = document.createElement('input');
    input.type = 'hidden'; input.name = 'return_to'; input.value = '/checkout';
    form.appendChild(input); form.submit();
  }
</script>

{% schema %}
{
  "name": "Main Product Grid",
  "settings": []
}
{% endschema %}
