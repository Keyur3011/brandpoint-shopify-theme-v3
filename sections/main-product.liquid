<!-- Advanced Premium Product Page Structure -->
<div class="product-page-container" data-product-handle="{{ product.handle }}">
  <div class="product-main-flex">
    
    <!-- 1. LEFT SIDE: Dynamic Product Gallery -->
    <div class="product-gallery">
      <div class="main-image-wrapper">
        <img id="MainProductImage" src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title }}" class="zoom-image">
      </div>
      <!-- Thumbnail Images -->
      <div class="product-thumbnails">
        {% for image in product.images %}
          <img src="{{ image | img_url: '150x150' }}" data-full-url="{{ image | img_url: '800x800' }}" class="thumb-img {% if forloop.first %}active-thumb{% endif %}">
        {% endfor %}
      </div>
    </div>

    <!-- 2. RIGHT SIDE: Product Details & Variant Swatches -->
    <div class="product-details-info">
      <h1 class="product-title-main">{{ product.title }}</h1>
      <div class="product-price-box">
        <span class="current-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="old-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      <!-- Advanced Variant Selector -->
      {% form 'product', product, id: "AddToCartForm" %}
        <!-- Shopify Hidden Native Select -->
        <select name="id" id="ProductSelectNative" style="display:none;">
          {% for variant in product.variants %}
            <option value="{{ variant.id }}" data-color="{{ variant.option1 | downcase }}" data-img="{{ variant.image.src | img_url: '800x800' }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}>
              {{ variant.title }}
            </option>
          {% endfor %}
        </select>

        <!-- Dynamic Visual Color Swatches (Round Shape) -->
        <div class="swatch-container color-swatches">
          <label class="swatch-label">Color:</label>
          <div class="swatch-flex">
            {% assign dynamic_colors = "black,white,red,blue,green,grey,beige" | split: ',' %}
            {% for variant in product.variants %}
              {% assign v_color = variant.option1 | downcase %}
              <div class="color-circle-wrapper" data-color-val="{{ v_color }}">
                <span class="color-circle" style="background-color: {% if dynamic_colors contains v_color %}{{ v_color }}{% else %}#ccc{% endif %};"></span>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Size Guide Trigger & Selector -->
        <div class="swatch-container size-swatches">
          <div class="size-header-flex">
            <label class="swatch-label">Size:</label>
            <span class="size-guide-trigger" onclick="toggleSizeModal(true)">Size Guide</span>
          </div>
          <div class="size-btn-flex">
            {% for variant in product.variants %}
              <button type="button" class="size-btn-opt" data-size-val="{{ variant.option2 }}">{{ variant.option2 }}</button>
            {% endfor %}
          </div>
        </div>

        <!-- Add To Cart Button -->
        <button type="submit" name="add" class="prime-add-btn">ADD TO BAG</button>
      {% endform %}
    </div>
  </div>

  <!-- 3. BOTTOM SECTION: Deep Tabs (Specification, FAQ, Reviews) -->
  <div class="product-deep-tabs-section">
    <div class="tabs-header">
      <button class="tab-link active" onclick="openTab(event, 'Specs')">Specifications</button>
      <button class="tab-link" onclick="openTab(event, 'FAQ')">FAQ</button>
      <button class="tab-link" onclick="openTab(event, 'Reviews')">Reviews</button>
    </div>

    <!-- Tab 1: Specs -->
    <div id="Specs" class="tab-content default-tab">
      <p>Premium streetwear tailoring featuring 100% heavy-weight loopback cotton. Pre-shrunk and silicone softened for an ultimate luxury hand-feel.</p>
    </div>

    <!-- Tab 2: FAQ -->
    <div id="FAQ" class="tab-content" style="display:none;">
      <div class="faq-item"><strong>Q: How do I wash this streetwear garment?</strong><p>A: Wash inside out in cold water, dry flat to maintain premium texture.</p></div>
      <div class="faq-item"><strong>Q: Is the fit oversized?</strong><p>A: Yes, it features a signature dropped-shoulder aesthetic.</p></div>
    </div>

    <!-- Tab 3: Reviews -->
    <div id="Reviews" class="tab-content" style="display:none;">
      <div class="review-row">⭐ ⭐ ⭐ ⭐ ⭐ <strong>Keyur C.</strong> - "The luxury look and drop shoulder fit is insane! Totally worth it."</div>
    </div>
  </div>
</div>

<!-- Size Guide Modal Box -->
<div id="SizeGuideModal" class="modal-overlay" style="display:none;">
  <div class="modal-box-body">
    <h3>Size Guide</h3>
    <table class="size-table-ui">
      <tr><th>Size</th><th>Chest (in)</th><th>Length (in)</th></tr>
      <tr><td>S</td><td>42</td><td>27</td></tr>
      <tr><td>M</td><td>44</td><td>28</td></tr>
      <tr><td>L</td><td>46</td><td>29</td></tr>
    </table>
    <button class="close-modal-btn" onclick="toggleSizeModal(false)">Close</button>
  </div>
</div>

<style>
  .product-page-container { max-width: 1200px; margin: 0 auto; padding: 20px; font-family: sans-serif; }
  .product-main-flex { display: flex; gap: 40px; flex-wrap: wrap; }
  .product-gallery, .product-details-info { flex: 1; min-width: 300px; }
  .main-image-wrapper img { width: 100%; border-radius: 8px; }
  .product-thumbnails { display: flex; gap: 10px; margin-top: 15px; }
  .thumb-img { width: 60px; height: 60px; object-fit: cover; border-radius: 4px; cursor: pointer; border: 2px solid transparent; }
  .active-thumb { border-color: #000; }
  
  /* Round Color Swatches */
  .swatch-container { margin: 20px 0; }
  .swatch-label { font-weight: 700; display: block; margin-bottom: 8px; font-size: 14px; text-transform: uppercase; }
  .swatch-flex { display: flex; gap: 12px; }
  .color-circle-wrapper { width: 32px; height: 32px; border-radius: 50%; border: 2px solid #ddd; display: flex; align-items: center; justify-content: center; cursor: pointer; }
  .color-circle-wrapper.selected-swatch { border-color: #000; }
  .color-circle { width: 24px; height: 24px; border-radius: 50%; display: block; }
  
  /* Size Swatches & Guide */
  .size-header-flex { display: flex; justify-content: space-between; }
  .size-guide-trigger { font-size: 12px; text-decoration: underline; cursor: pointer; color: #555; }
  .size-btn-flex { display: flex; gap: 10px; }
  .size-btn-opt { padding: 10px 20px; border: 1px solid #ccc; background: #fff; cursor: pointer; font-weight: 600; }
  .size-btn-opt.active-size { background: #000; color: #fff; border-color: #000; }

  .prime-add-btn { width: 100%; background: #000; color: #fff; padding: 16px; border: none; font-weight: 700; letter-spacing: 1px; cursor: pointer; margin-top: 20px; }
  
  /* Deep Tabs Styling */
  .product-deep-tabs-section { margin-top: 60px; border-top: 1px solid #eee; padding-top: 30px; }
  .tabs-header { display: flex; gap: 20px; border-bottom: 1px solid #eee; }
  .tab-link { background: none; border: none; padding: 10px 20px; font-size: 16px; font-weight: 600; cursor: pointer; color: #888; }
  .tab-link.active { color: #000; border-bottom: 2px solid #000; }
  .tab-content { padding: 20px 0; line-height: 1.6; }

  /* Modal System */
  .modal-overlay { position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:999; }
  .modal-box-body { background:#fff; padding:30px; border-radius:8px; width:90%; max-width:400px; }
  .size-table-ui { width:100%; margin:20px 0; border-collapse:collapse; }
  .size-table-ui th, .size-table-ui td { border:1px solid #ddd; padding:10px; text-align:center; }
  .close-modal-btn { background:#000; color:#fff; width:100%; padding:10px; border:none; cursor:pointer; }
</style>

<script>
  // Dynamic Variant Swatch Logic
  document.querySelectorAll('.color-circle-wrapper').forEach(wrapper => {
    wrapper.addEventListener('click', function() {
      document.querySelectorAll('.color-circle-wrapper').forEach(w => w.classList.remove('selected-swatch'));
      this.classList.add('selected-swatch');
      
      const targetColor = this.getAttribute('data-color-val');
      const nativeSelect = document.getElementById('ProductSelectNative');
      
      // Look for variant with matching color and update image
      for (let option of nativeSelect.options) {
        if (option.getAttribute('data-color') === targetColor) {
          nativeSelect.value = option.value;
          const newImgUrl = option.getAttribute('data-img');
          if (newImgUrl) {
            document.getElementById('MainProductImage').src = newImgUrl;
          }
          break;
        }
      }
    });
  });

  // Tab Control System
  function openTab(evt, tabName) {
    document.querySelectorAll('.tab-content').forEach(content => content.style.display = 'none');
    document.querySelectorAll('.tab-link').forEach(link => link.classList.remove('active'));
    document.getElementById(tabName).style.display = 'block';
    evt.currentTarget.classList.add('active');
  }

  // Size Modal System
  function toggleSizeModal(show) {
    document.getElementById('SizeGuideModal').style.display = show ? 'flex' : 'none';
  }
</script>

{% schema %}
{
  "name": "Main Product Premium",
  "settings": []
}
{% endschema %}
