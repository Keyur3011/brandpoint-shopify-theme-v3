<div class="premium-product-wrapper">
  <div class="premium-product-container">
    
    <div class="product-media-gallery">
      <div class="main-image-holder">
        {% if product.featured_image %}
          <img id="MainProductImage" src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title | escape }}">
        {% else %}
          <img src="https://images.unsplash.com/photo-1618886614638-80e3c103d31a?auto=format&fit=crop&q=80&w=800" alt="Placeholder">
        {% endif %}
      </div>
      
      {% if product.images.size > 1 %}
        <div class="product-thumbnails-grid">
          {% for image in product.images %}
            <div class="thumb-image-card {% if forloop.first %}active-thumb{% endif %}" data-image-id="{{ image.id }}" onclick="switchProductImage('{{ image | img_url: 'master' }}', this)">
              <img src="{{ image | img_url: '200x200', crop: 'center' }}" alt="{{ image.alt | escape | default: product.title | escape }}">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-info-panel">
      <h1 class="brand-product-title">{{ product.title }}</h1>
      
      <!-- ⭐ JUDGE.ME STAR RATING BADGE UNDER TITLE -->
      <div style="margin-bottom: 15px;">
        <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}"></div>
      </div>
      
      <div class="brand-price-container">
        <span class="current-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="compare-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% form 'product', product, id: 'PremiumProductForm' %}
        <input type="hidden" name="id" id="MasterVariantId" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="product-variants-selectors">
          {% for option in product.options_with_values %}
            <div class="variant-option-group" data-option-index="{{ forloop.index0 }}" data-option-name="{{ option.name | downcase }}">
              <label class="variant-label">{{ option.name | upcase }}:</label>
              <div class="variant-values-list">
                {% for value in option.values %}
                  {% assign is_color = false %}
                  {% assign option_name_lower = option.name | downcase %}
                  {% if option_name_lower contains 'color' or option_name_lower contains 'colour' %}
                    {% assign is_color = true %}
                  {% endif %}

                  {% if is_color %}
                    <span class="color-swatch-circle {% if option.selected_value == value %}active-swatch{% endif %}" data-value="{{ value | escape }}" style="background-color: {{ value | downcase }};" title="{{ value | escape }}"></span>
                  {% else %}
                    <span class="size-swatch-box {% if option.selected_value == value %}active-swatch{% endif %}" data-value="{{ value | escape }}">{{ value }}</span>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="quantity-selector-wrapper">
          <label class="variant-label">QUANTITY</label>
          <div class="quantity-input-box">
            <button type="button" onclick="changeQty(-1)">-</button>
            <input type="number" id="ProductQtyInput" name="quantity" value="1" min="1">
            <button type="button" onclick="changeQty(1)">+</button>
          </div>
        </div>

        <div class="action-buttons-stack">
          <button type="submit" class="btn-add-to-bag">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            ADD TO CART
          </button>
          <button type="button" class="btn-buy-now" onclick="triggerDirectCheckout()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
            BUY NOW
          </button>
        </div>
      {% endform %}

      <!-- WORKING WHATSAPP ORDER BUTTON -->
      {% assign whatsapp_message = "Hi, I want to order " | append: product.title | append: " - Price: " | append: product.price | money_without_currency | append: ". Link: " | append: shop.url | append: product.url %}
      <a href="https://wa.me/919316025323?text={{ whatsapp_message | url_encode }}" target="_blank" class="whatsapp-order-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397 0 11.948 0c3.174.001 6.161 1.24 8.413 3.488 2.253 2.248 3.492 5.232 3.492 8.406-.003 6.549-5.34 11.897-11.891 11.897-2.006-.002-3.973-.508-5.714-1.472L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.755 1.451 5.352 0 9.713-4.346 9.716-9.693.001-2.59-1.006-5.025-2.834-6.855C16.404 2.228 13.976 1 11.95 1 6.599 1 2.239 5.348 2.236 10.697c-.001 1.637.452 3.232 1.311 4.647L2.518 20.9l5.69-1.492c-.22.1-.21.09-.56-.154z"/></svg>
        ORDER ON WHATSAPP
      </a>

      <!-- DYNAMIC PRODUCT DESCRIPTION SECTION -->
      {% if product.description != blank %}
        <div class="product-description-container" style="margin-top: 10px; margin-bottom: 30px; border-top: 1px solid #1a1a1a; padding-top: 20px;">
          <label class="variant-label" style="margin-bottom: 12px;">DESCRIPTION</label>
          <div class="product-description-content" style="font-size: 14px; color: #ccc; line-height: 1.6; font-weight: 400;">
            {{ product.description }}
          </div>
        </div>
      {% endif %}

      <div class="trust-pillars-grid">
        <div class="pillar-card">
          <span class="pillar-icon">🔒</span>
          <div>
            <h4>Secure Payment</h4>
            <p>100% safe checkout</p>
          </div>
        </div>
        <div class="pillar-card">
          <span class="pillar-icon">🔄</span>
          <div>
            <h4>Easy Returns</h4>
            <p>7-day return policy</p>
          </div>
        </div>
        <div class="pillar-card">
          <span class="pillar-icon">✨</span>
          <div>
            <h4>Premium Quality</h4>
            <p>Luxury craftsmanship</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- 📦 CUSTOM MOBILE-RESPONSIVE PREMIUM REVIEW SECTION WITH ENGINE -->
<div class="premium-review-section" style="border-top: 1px solid #1a1a1a; padding: 60px 15px; background: #000000;">
  <div class="custom-jdgm-box-container" style="max-width: 800px; margin: 0 auto;">
    <!-- Start of Judge.me code -->
    {% assign has_legacy = false %}
    {% if product.metafields.judgeme.widget.size > 20 %}
      {% assign has_legacy = true %}
    {% endif %}
    <div style='clear:both'></div>
    <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-product-id='{{ product.id }}' data-widget='review' data-auto-install='false' data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' data-entry-point='review_widget.js' data-entry-key='review-widget/main.js'>
      {% if has_legacy %}
        <div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>
      {% endif %}
    </div>
    {% if product.metafields.judgeme.review_widget_data %}
      <script>
        window.jdgm = window.jdgm || {};
        jdgm.data ||= {}; 
        jdgm.data.reviewWidget ||= {}; 
        jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }};
      </script>
    {% endif %}
    <!-- End of Judge.me code -->
  </div>
</div>

<script id="ProductJson-Data" type="application/json">
  [
    {% for variant in product.variants %}
      {
        "id": {{ variant.id }},
        "options": {{ variant.options | json }},
        "price": {{ variant.price }},
        "featured_image": {% if variant.featured_image %}{ "id": {{ variant.featured_image.id }} }{% else %}null{% endif %}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
</script>

<style>
  .premium-product-wrapper { background-color: #000000; color: #ffffff; padding: 40px 15px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .premium-product-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 40px; }
  
  /* Media Gallery */
  .main-image-holder { width: 100%; aspect-ratio: 3/4; border-radius: 12px; overflow: hidden; background-color: #111; }
  .main-image-holder img { width: 100%; height: 100%; object-fit: cover; }
  .product-thumbnails-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-top: 15px; }
  .thumb-image-card { aspect-ratio: 1/1; border-radius: 6px; overflow: hidden; border: 1px solid #222; cursor: pointer; }
  .thumb-image-card img { width: 100%; height: 100%; object-fit: cover; }
  .active-thumb { border-color: #ffffff; }

  /* Info Panel */
  .brand-product-title { font-size: 26px; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 10px; }
  .brand-price-container { margin-bottom: 25px; display: flex; align-items: center; gap: 12px; }
  .current-price { font-size: 22px; font-weight: 700; }
  .compare-price { font-size: 16px; color: #666; text-decoration: line-through; }

  /* Swatches - Active/Selected Look */
  .variant-option-group { margin-bottom: 20px; }
  .variant-label { display: block; font-size: 12px; font-weight: 600; color: #888; letter-spacing: 1px; margin-bottom: 10px; }
  .variant-values-list { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
  
  .color-swatch-circle { width: 28px; height: 28px; border-radius: 50%; display: inline-block; border: 2px solid #333; cursor: pointer; transition: 0.2s; position: relative; }
  .color-swatch-circle:hover { transform: scale(1.1); }
  
  .size-swatch-box { padding: 8px 16px; border: 1px solid #333; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; transition: 0.2s; background: transparent; color: #fff; }
  .size-swatch-box:hover { border-color: #fff; }
  
  /* Active Border Styles for Selection */
  .color-swatch-circle.active-swatch { border-color: #ffffff !important; box-shadow: 0 0 8px #ffffff; }
  .size-swatch-box.active-swatch { border-color: #ffffff !important; background-color: #ffffff !important; color: #000000 !important; font-weight: 700; }

  /* Qty Counter */
  .quantity-selector-wrapper { margin-bottom: 30px; }
  .quantity-input-box { display: flex; align-items: center; width: 120px; border: 1px solid #333; border-radius: 6px; height: 40px; }
  .quantity-input-box button { width: 40px; height: 100%; background: none; border: none; color: #fff; font-size: 18px; cursor: pointer; }
  .quantity-input-box input { width: 40px; text-align: center; background: none; border: none; color: #fff; font-size: 14px; -appearance: textfield; }

  /* Action Buttons */
  .action-buttons-stack { display: flex; flex-direction: column; gap: 12px; margin-bottom: 15px; }
  .btn-add-to-bag, .btn-buy-now { width: 100%; height: 52px; font-weight: 700; font-size: 14px; letter-spacing: 1px; border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 10px; cursor: pointer; transition: 0.2s; }
  
  .btn-add-to-bag { background-color: #ffffff; color: #000000; border: none; }
  .btn-add-to-bag:hover { background-color: #eeeeee; }
  
  .btn-buy-now { background-color: #000000; color: #ffffff; border: 1px solid #ffffff; }
  .btn-buy-now:hover { background-color: #111111; }

  /* WhatsApp & Badges */
  .whatsapp-order-btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; height: 52px; border: 1px solid #075E54; border-radius: 8px; color: #25D366; text-decoration: none; font-weight: 700; font-size: 14px; margin-bottom: 15px; }
  
  /* Description content style reset for safety */
  .product-description-content p, .product-description-content ul, .product-description-content li { color: #ccc !important; background: transparent !important; }

  .trust-pillars-grid { display: grid; grid-template-columns: 1fr; gap: 15px; border-top: 1px solid #222; padding-top: 25px; }
  .pillar-card { background-color: #0a0a0a; border: 1px solid #111; border-radius: 8px; padding: 15px; display: flex; align-items: center; gap: 15px; }
  .pillar-icon { font-size: 20px; }
  .pillar-card h4 { font-size: 14px; font-weight: 600; margin: 0 0 2px 0; }
  .pillar-card p { font-size: 12px; color: #666; margin: 0; }

  /* 🎨 JUDGE.ME UI PREMIUM BOX STYLING WITH MOBILE OVERRIDES */
  .custom-jdgm-box-container .jdgm-widget {
    background: #0d0d0d !important;
    border: 1px solid #222 !important;
    border-radius: 12px !important;
    padding: 25px !important;
    color: #ffffff !important;
    box-sizing: border-box !important;
  }
  .custom-jdgm-box-container .jdgm-write-rev-link {
    background: #ffffff !important;
    color: #000000 !important;
    display: inline-block !important;
    padding: 12px 24px !important;
    border-radius: 6px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
  }
  .custom-jdgm-box-container .jdgm-form__fieldset--reviewer-info .jdgm-form__fieldset-title {
    display: none !important;
  }
  .custom-jdgm-box-container .jdgm-form__label {
    color: #888 !important;
    font-size: 12px !important;
  }
  .custom-jdgm-box-container .jdgm-form__input {
    background: #151515 !important;
    border: 1px solid #333 !important;
    color: #fff !important;
    border-radius: 6px !important;
    box-sizing: border-box !important;
    width: 100% !important;
  }

  /* 📱 MOBILE EXCLUSIVE PRESETS (BOX TYPES & SCALING FOR EXTRA SMALL SCREENS) */
  @media (max-width: 767px) {
    .custom-jdgm-box-container .jdgm-widget {
      padding: 15px !important;
    }
    .custom-jdgm-box-container .jdgm-form__fieldset {
      margin-bottom: 12px !important;
      padding: 0 !important;
    }
    .custom-jdgm-box-container .jdgm-form__actions {
      display: flex !important;
      flex-direction: column !important;
      gap: 10px !important;
    }
    .custom-jdgm-box-container .jdgm-submit-rev, 
    .custom-jdgm-box-container .jdgm-form__actions .jdgm-btn {
      width: 100% !important;
      box-sizing: border-box !important;
      padding: 12px !important;
      font-size: 14px !important;
      text-align: center !important;
    }
    /* Fixing potential overflowing layout containers in Judge.me */
    .jdgm-form, .jdgm-row, .jdgm-col {
      width: 100% !important;
      max-width: 100% !important;
      float: none !important;
      padding: 0 !important;
      margin: 0 0 10px 0 !important;
      box-sizing: border-box !important;
    }
  }

  @media (min-width: 768px) {
    .premium-product-container { grid-template-columns: 1.1fr 0.9fr; gap: 60px; }
    .trust-pillars-grid { grid-template-columns: repeat(3, 1fr); }
    .action-buttons-stack { flex-direction: row; }
  }
</style>

<script>
  function switchProductImage(imgUrl, element) {
    document.getElementById('MainProductImage').src = imgUrl;
    document.querySelectorAll('.thumb-image-card').forEach(thumb => thumb.classList.remove('active-thumb'));
    if(element) element.classList.add('active-thumb');
  }

  function changeQty(amount) {
    var input = document.getElementById('ProductQtyInput');
    var current = parseInt(input.value);
    if(current + amount >= 1) { input.value = current + amount; }
  }

  function triggerDirectCheckout() {
    var variantId = document.getElementById('MasterVariantId').value;
    var quantity = document.getElementById('ProductQtyInput').value;

    fetch('/cart/clear.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    })
    .then(function() {
      var formData = {
        'items': [{
          'id': parseInt(variantId),
          'quantity': parseInt(quantity)
        }]
      };
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });
    })
    .then(function() {
      window.location.href = '/checkout';
    })
    .catch(function(error) {
      console.error('Checkout Error:', error);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    const dataEl = document.getElementById('ProductJson-Data');
    if(!dataEl) return;
    
    const variantsData = JSON.parse(dataEl.innerHTML);
    const swatchGroups = document.querySelectorAll('.variant-option-group');

    function updateSelectedVariant() {
      let selectedOptions = [];
      
      swatchGroups.forEach(group => {
        const activeSwatch = group.querySelector('.active-swatch');
        if (activeSwatch) {
          selectedOptions.push(activeSwatch.getAttribute('data-value'));
        }
      });

      const matchedVariant = variantsData.find(variant => {
        return variant.options.every((option, index) => option === selectedOptions[index]);
      });

      if (matchedVariant) {
        const masterInput = document.getElementById('MasterVariantId');
        if(masterInput) masterInput.value = matchedVariant.id;
        
        const newUrl = window.location.pathname + '?variant=' + matchedVariant.id;
        window.history.replaceState({ path: newUrl }, '', newUrl);

        const priceContainer = document.querySelector('.current-price');
        if (priceContainer) {
          priceContainer.innerHTML = window.Shopify ? Shopify.formatMoney(matchedVariant.price, "{{ shop.money_format }}") : (matchedVariant.price / 100).toFixed(2);
        }

        if (matchedVariant.featured_image && matchedVariant.featured_image.id) {
          const targetThumb = document.querySelector(`.thumb-image-card[data-image-id="${matchedVariant.featured_image.id}"]`);
          if (targetThumb) {
            targetThumb.click();
          }
        }
      }
    }

    swatchGroups.forEach(group => {
      const swatches = group.querySelectorAll('.color-swatch-circle, .size-swatch-box');

      swatches.forEach(swatch => {
        if (!group.querySelector('.active-swatch')) {
          swatches[0].classList.add('active-swatch');
        }

        swatch.addEventListener('click', function() {
          group.querySelectorAll('.color-swatch-circle, .size-swatch-box').forEach(s => s.classList.remove('active-swatch'));
          this.classList.add('active-swatch');
          
          updateSelectedVariant();
        });
      });
    });

    updateSelectedVariant();
  });
</script>

{% schema %}
{
  "name": "Main Product Grid",
  "settings": []
}
{% endschema %}
