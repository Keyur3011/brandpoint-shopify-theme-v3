        </div>
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="rating-count">(124)</span>
        </div>
      </div>
    </div>

    <!-- Dummy Product 4 -->
    <div class="product-card">
      <div class="product-image-wrapper">
        <span class="discount-badge">-25%</span>
        <div class="product-image" style="background-image: url('https://images.unsplash.com/photo-1549298916-b41d501d3772?auto=format&fit=crop&q=80&w=500');"></div>
      </div>
      <div class="product-info">
        <h3 class="product-item-title">Minimal Sneakers</h3>
        <div class="product-price-box">
          <span class="price-current">₹4,499</span>
          <span class="price-old">₹5,999</span>
        </div>
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="rating-count">(124)</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Center Action Button -->
  <div class="view-all-container">
    <a href="/collections/all" class="btn-view-all">VIEW ALL PRODUCTS</a>
  </div>
</div>

<style>
  .product-grid-section {
    background-color: #000000;
    padding: 50px 15px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 35px;
  }

  .section-title {
    font-size: 26px;
    font-weight: 500;
    color: #ffffff;
    letter-spacing: 3px;
    margin: 0 0 8px 0;
    text-transform: uppercase;
  }

  .section-subtitle {
    font-size: 11px;
    color: #777777;
    letter-spacing: 1px;
    margin: 0;
  }

  /* Matching your mobile layout perfectly: 2 Columns */
  .main-products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px 12px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .product-card {
    background-color: transparent;
    display: flex;
    flex-direction: column;
  }

  .product-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #111111;
    overflow: hidden;
    border-radius: 4px;
  }

  .product-image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }

  /* Discount Badge Style */
  .discount-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: #000000;
    color: #ffffff;
    font-size: 9px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 12px;
    z-index: 2;
    border: 1px solid rgba(255,255,255,0.2);
  }

  .product-info {
    padding: 12px 2px 0 2px;
  }

  .product-item-title {
    font-size: 13px;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 6px 0;
    letter-spacing: 0.5px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-price-box {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .price-current {
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
  }

  .price-old {
    font-size: 11px;
    color: #666666;
    text-decoration: line-through;
  }

  /* Star Ratings */
  .product-rating {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .stars {
    color: #ffcc00; /* Beautiful Yellow Stars */
    font-size: 11px;
    letter-spacing: 1px;
  }

  .rating-count {
    color: #666666;
    font-size: 10px;
  }

  /* View All Button */
  .view-all-container {
    text-align: center;
    margin-top: 40px;
  }

  .btn-view-all {
    display: inline-block;
    border: 1px solid #ffffff;
    color: #ffffff;
    background: transparent;
    padding: 12px 35px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .btn-view-all:hover {
    background-color: #ffffff;
    color: #000000;
  }

  /* Desktop View Grid Expansion */
  @media (min-width: 992px) {
    .main-products-grid {
      grid-template-columns: repeat(4, 1fr); /* 4 Columns on Desktop */
      gap: 30px 20px;
    }
    .product-item-title {
      font-size: 14px;
    }
    .price-current {
      font-size: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Product Grid",
  "settings": []
}
{% endschema %}
