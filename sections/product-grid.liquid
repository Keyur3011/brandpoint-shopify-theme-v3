    <!-- Dummy Product 2 -->
    <div class="product-card">
      <div class="product-image-wrapper">
        <span class="discount-badge">-33%</span>
        <div class="product-image" style="background-image: url('https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?auto=format&fit=crop&q=80&w=500');"></div>
      </div>
      <div class="product-info">
        <h3 class="product-item-title">Relaxed Fit Shirt</h3>
        <div class="product-price-box">
          <span class="price-current">₹2,899</span>
          <span class="price-old">₹4,499</span>
        </div>
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="rating-count">(124)</span>
        </div>
      </div>
    </div>

    <!-- Dummy Product 3 -->
    <div class="product-card">
      <div class="product-image-wrapper">
        <span class="discount-badge">-38%</span>
        <div class="product-image" style="background-image: url('https://images.unsplash.com/photo-1556905055-8f358a7a47b2?auto=format&fit=crop&q=80&w=500');"></div>
      </div>
      <div class="product-info">
        <h3 class="product-item-title">Designer Tracksuit</h3>
        <div class="product-price-box">
          <span class="price-current">₹7,999</span>
