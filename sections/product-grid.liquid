<!-- Brand Point Ultra-Luxury Automatic New Arrivals Grid -->
<section class="luxury-new-arrivals-section">
  <div class="arrivals-header-block">
    <h2 class="arrivals-main-title">NEW ARRIVALS</h2>
    <p class="arrivals-sub-title">The latest drops from the streets</p>
    <div class="luxury-gold-line-accent"></div>
  </div>

  <!-- Dynamic Product Grid Loop -->
  <div class="luxury-products-grid-container">
    {%- assign arrival_collection = collections['new-arrivals'] -%}
    
    {%- if arrival_collection != blank and arrival_collection.products_count > 0 -%}
      {%- for product in arrival_collection.products limit: 4 -%}
        
        <!-- Individual Product Card -->
        <div class="luxury-product-card-item">
          <a href="{{ product.url }}" class="luxury-card-image-link">
            <div class="luxury-card-image-wrapper">
              <img 
                src="{{ product.featured_image | img_url: '600x750', crop: 'center' }}" 
                alt="{{ product.title | escape }}" 
                class="luxury-card-main-img"
                loading="lazy"
              >
              <!-- Hidden or hover secondary image if exists for elite brand feel -->
              {%- if product.images[1] != blank -%}
                <img src="{{ product.images[1] | img_url: '600x750', crop: 'center' }}" class="luxury-card-hover-img" loading="lazy">
              {%- endif -%}
              
              <div class="luxury-card-overlay-glow"></div>
            </div>
          </a>

          <!-- Info Details -->
          <div class="luxury-card-info-box">
            <span class="luxury-card-vendor">{{ product.vendor | uppercase }}</span>
            <h3 class="luxury-card-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
            
            <div class="luxury-card-price-row">
              <span class="luxury-card-price">{{ product.price | money }}</span>
              <span class="luxury-card-stars">★★★★★</span>
            </div>
          </div>
        </div>

      {%- endfor -%}
    {%- else -%}
      <!-- Fallback Placeholder: अगर कलेक्शन खाली है -->
      {%- for i in (1..4) -%}
        <div class="luxury-product-card-item placeholder-state">
          <div class="luxury-card-image-wrapper" style="background: #111; height: 320px;"></div>
          <p style="color: #444; font-size: 11px; margin-top: 10px; letter-spacing: 1px;">TAG A PRODUCT WITH 'NEW-ARRIVAL'</p>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<!-- ========================================== -->
<!-- HIGH-END LUXURY CODE STYLING ARCHITECTURE -->
<!-- ========================================== -->
<style>
  .luxury-new-arrivals-section {
    background-color: #000000;
    color: #ffffff;
    padding: 80px 24px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .arrivals-header-block {
    text-align: center;
    margin-bottom: 45px;
  }

  .arrivals-main-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: 5px;
    margin: 0 0 10px 0;
  }

  .arrivals-sub-title {
    font-size: 12px;
    color: #666666;
    letter-spacing: 1.5px;
    margin: 0 0 18px 0;
  }

  .luxury-gold-line-accent {
    height: 1px;
    width: 50px;
    background: #D4AF37;
    margin: 0 auto;
  }

  /* Highly Responsive Luxury Grid Layout */
  .luxury-products-grid-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Mobile layout: perfectly split 2-columns */
    gap: 30px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 769px) {
    .luxury-products-grid-container {
      grid-template-columns: repeat(4, 1fr); /* Desktop layout: 4-columns inline */
    }
  }

  /* Card Architecture */
  .luxury-product-card-item {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .luxury-card-image-link {
    display: block;
    width: 100%;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .luxury-card-image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 130%; /* 4:5.2 Streetwear Premium Aspect Ratio */
    background-color: #111;
    overflow: hidden;
  }

  .luxury-card-main-img, .luxury-card-hover-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;
  }

  .luxury-card-hover-img {
    opacity: 0;
  }

  /* Elite Image Swap Effect on Hover */
  .luxury-product-card-item:hover .luxury-card-main-img {
    transform: scale(1.03);
  }
  
  @media (min-width: 769px) {
    .luxury-product-card-item:hover .luxury-card-hover-img {
      opacity: 1;
      transform: scale(1.03);
    }
  }

  .luxury-card-overlay-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, transparent 80%, rgba(0,0,0,0.1) 100%);
    pointer-events: none;
  }

  /* Details Card */
  .luxury-card-info-box {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: left;
    padding: 0 4px;
  }

  .luxury-card-vendor {
    font-size: 10px;
    color: #555555;
    letter-spacing: 1.5px;
    font-weight: 600;
  }

  .luxury-card-title {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin: 0;
    line-height: 1.4;
  }

  .luxury-card-title a {
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .luxury-card-title a:hover {
    color: #D4AF37;
  }

  .luxury-card-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2px;
  }

  .luxury-card-price {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
  }

  .luxury-card-stars {
    color: #D4AF37;
    font-size: 9px;
    letter-spacing: 1px;
  }

  @media (max-width: 480px) {
    .arrivals-main-title { font-size: 22px; letter-spacing: 4px; }
    .luxury-card-title { font-size: 13px; }
  }
</style>

{% schema %}
{
  "name": "Luxury Auto Arrivals",
  "settings": [],
  "presets": [
    {
      "name": "Luxury Auto Arrivals"
    }
  ]
}
{% endschema %}
