<div class="category-section">
  <div class="section-header">
    <h2 class="section-title">SHOP BY CATEGORY</h2>
    <p class="section-subtitle">Explore our curated collections</p>
  </div>

  <div class="category-grid">
    <a href="/collections/shirts" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://images.unsplash.com/photo-1596755094514-f87e34085b2c?auto=format&fit=crop&q=80&w=600');"></div>
      <div class="category-text">SHIRTS</div>
    </a>

    <a href="/collections/denim" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://images.unsplash.com/photo-1542272604-787c3835535d?auto=format&fit=crop&q=80&w=600');"></div>
      <div class="category-text">DENIM</div>
    </a>

    <a href="/collections/t-shirts" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://images.unsplash.com/photo-1521572267360-ee0c2909d518?auto=format&fit=crop&q=80&w=600');"></div>
      <div class="category-text">T-SHIRTS</div>
    </a>

    <a href="/collections/cord-set" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://images.unsplash.com/photo-1608234807905-446585f3c602?auto=format&fit=crop&q=80&w=600');"></div>
      <div class="category-text">CORD SET</div>
    </a>

    <a href="/collections/track-pants" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://images.unsplash.com/photo-1551854838-212c50b4c184?auto=format&fit=crop&q=80&w=600');"></div>
      <div class="category-text">TRACK</div>
    </a>

    <a href="/collections/accessories" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://images.unsplash.com/photo-1576053139778-7e32f2ae3cfd?auto=format&fit=crop&q=80&w=600');"></div>
      <div class="category-text">ACCESSORIES</div>
    </a>
  </div>
</div>

<style>
  .category-section {
    background-color: #000000;
    padding: 60px 20px;
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .section-title {
    color: #ffffff;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 3px;
    margin: 0 0 10px 0;
  }
  .section-subtitle {
    color: #888888;
    font-size: 14px;
    letter-spacing: 1px;
    margin: 0;
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .category-card {
    position: relative;
    height: 250px;
    border: 1px solid #111111;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    z-index: 1;
  }
  .category-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: -2;
  }
  .category-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    transition: background-color 0.3s ease;
    z-index: -1;
    pointer-events: none; /* यह बटनों को तुरंत एक्टिव कर देगा */
  }
  .category-text {
    color: #ffffff;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    z-index: 2;
  }
  
  /* Hover Effects */
  .category-card:hover .category-image {
    transform: scale(1.08);
  }
  .category-card:hover .category-overlay {
    background-color: rgba(0, 0, 0, 0.2);
  }

  @media (min-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }
    .category-card {
      height: 350px;
    }
    .section-title {
      font-size: 36px;
    }
  }
</style>

{% schema %}
{
  "name": "Category Grid",
  "settings": [],
  "presets": [
    {
      "name": "Category Grid"
    }
  ]
}
{% endschema %}

