<div class="category-section">
  <div class="section-header">
    <h2 class="section-title">SHOP BY CATEGORY</h2>
    <p class="section-subtitle">Explore our curated collections</p>
  </div>

  <div class="category-grid">
    <a href="/collections/shirts" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://cdn.shopify.com/s/files/1/0811/5716/1212/files/1eaabf158ea5aa381e4b72ac390c5768_1.jpg?v=1784124920');"></div>
      <div class="category-text">SHIRTS</div>
    </a>

    <a href="/collections/denim" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://cdn.shopify.com/s/files/1/0811/5716/1212/files/96597c5e6336df569b4a5977d7accc4a5e88d841a57b8152965a299037332854_1.png?v=1784124767');"></div>
      <div class="category-text">DENIM</div>
    </a>

    <a href="/collections/t-shirts" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://cdn.shopify.com/s/files/1/0811/5716/1212/files/file_0000000003bc7206a58062f9ebe1503c_1.png?v=1784124903');"></div>
      <div class="category-text">T-SHIRTS</div>
    </a>

    <a href="/collections/co-ord-sets" class="category-card">
      <div class="category-overlay"></div>
      <div class="category-image" style="background-image: url('https://cdn.shopify.com/s/files/1/0811/5716/1212/files/d211733ea295e2578021583a0640aee2_1.jpg?v=1784124938');"></div>
      <div class="category-text">CORD SET</div>
    </a>

    <a href="/collections/track-pants" class="category-card">
      <div class="category-overlay"></div>
      <!-- नीचे आपकी नई ट्रैक वाली इमेज का लिंक जोड़ दिया गया है -->
      <div class="category-image" style="background-image: url('https://cdn.shopify.com/s/files/1/0811/5716/1212/files/76183867-B2E8-4FCD-A90E-7383173A2795_1.png?v=1784209021');"></div>
      <div class="category-text">TRACK</div>
    </a>

    <a href="/collections/accessories" class="category-card">
      <div class="category-overlay"></div>
      <!-- नीचे आपकी नई एक्सेसरीज वाली इमेज का लिंक जोड़ दिया गया है -->
      <div class="category-image" style="background-image: url('https://cdn.shopify.com/s/files/1/0811/5716/1212/files/AC3AB3CC-EF9C-48D9-965E-666988BA79D4.png?v=1784277122');"></div>
      <div class="category-text">ACCESSORIES</div>
    </a>
  </div>
</div>

<style>
  .category-section {
    background-color: #000000;
    padding: 60px 20px;
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .section-title {
    color: #ffffff;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 3px;
    margin: 0 0 10px 0;
  }
  .section-subtitle {
    color: #888888;
    font-size: 14px;
    letter-spacing: 1px;
    margin: 0;
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .category-card {
    position: relative;
    height: 250px;
    border: 1px solid #111111;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    z-index: 1;
  }
  .category-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: -2;
  }
  .category-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    transition: background-color 0.3s ease;
    z-index: -1;
    pointer-events: none;
  }
  .category-text {
    color: #ffffff;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    z-index: 2;
  }
  
  .category-card:hover .category-image {
    transform: scale(1.08);
  }
  .category-card:hover .category-overlay {
    background-color: rgba(0, 0, 0, 0.2);
  }

  @media (min-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }
    .category-card {
      height: 350px;
    }
    .section-title {
      font-size: 36px;
    }
  }
</style>

{% schema %}
{
  "name": "Category Grid",
  "settings": [],
  "presets": [
    {
      "name": "Category Grid"
    }
  ]
}
{% endschema %}
