<!-- ========================================== -->
<!-- HIGH-END LUXURY STYLING ARCHITECTURE -->
<!-- ========================================== -->
<style>
  .premium-testimonials-section {
    background-color: #000000;
    color: #ffffff;
    padding: 80px 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    overflow: hidden;
    width: 100%;
  }

  .testimonials-header-block {
    text-align: center;
    margin-bottom: 50px;
    padding: 0 20px;
  }

  .testimonials-main-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: 4px;
    color: #ffffff;
    margin: 0 0 12px 0;
    text-transform: uppercase;
  }

  .testimonials-sub-title {
    font-size: 13px;
    color: #666666;
    letter-spacing: 1px;
    margin: 0 0 20px 0;
  }

  .luxury-title-gold-accent {
    height: 1px;
    width: 60px;
    background: linear-gradient(90deg, transparent, #D4AF37, transparent);
    margin: 0 auto;
  }

  /* Infinite Scrolling Track Engine */
  .luxury-scroller-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 20px 0;
  }

  /* Smooth linear infinite loop animation */
  .luxury-scroller-track {
    display: flex;
    width: max-content;
    gap: 30px;
    animation: luxuryFloatLeft 30s linear infinite;
  }

  /* Pause scrolling on hover so clients can read carefully */
  .luxury-scroller-container:hover .luxury-scroller-track {
    animation-play-state: paused;
  }

  /* High-End Circular / Rounded Capsule Card */
  .luxury-review-card-round {
    width: 320px;
    height: 320px;
    border-radius: 50%; /* Perfect Round Shape */
    background: radial-gradient(100% 100% at 0% 0%, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0) 100%);
    border: 1px solid rgba(212, 175, 55, 0.15); /* Soft, subtle gold border edge */
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    padding: 40px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  /* Premium Hover Elevation Effect */
  .luxury-review-card-round:hover {
    border-color: rgba(212, 175, 55, 0.6);
    box-shadow: 0 15px 40px rgba(212, 175, 55, 0.08);
    transform: translateY(-5px) scale(1.02);
  }

  .review-card-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .gold-stars-row {
    color: #D4AF37;
    font-size: 13px;
    letter-spacing: 3px;
    margin-bottom: 15px;
    text-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
  }

  .review-quote-text {
    font-size: 12px;
    color: #cccccc;
    line-height: 1.6;
    font-style: italic;
    font-weight: 400;
    margin: 0 0 18px 0;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .reviewer-meta-data {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .reviewer-name {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: #ffffff;
    text-transform: uppercase;
  }

  .reviewer-name-link {
    color: #ffffff;
    text-decoration: none;
  }

  .reviewer-location {
    font-size: 10px;
    color: #555555;
    letter-spacing: 0.5px;
  }

  /* Keyframe for Butter-Smooth Left-to-Right Loop CSS Execution */
  @keyframes luxuryFloatLeft {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-350px * 4)); 
    }
  }

  /* Responsive Scaling for smaller phone viewports */
  @media (max-width: 480px) {
    .testimonials-main-title { font-size: 22px; letter-spacing: 3px; }
    .luxury-review-card-round { width: 280px; height: 280px; padding: 30px; }
    @keyframes luxuryFloatLeft {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-310px * 4)); }
    }
  }
</style>

