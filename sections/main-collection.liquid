<div class="brand-collection-wrapper">
  <div class="brand-collection-container">
    
    <div class="collection-intro-header">
      <h1 class="main-collection-title">{{ collection.title | upcase }}</h1>
      <p class="main-collection-subtitle">Premium Indian Streetwear & Luxury Casual Fashion</p>
    </div>

    <div class="figma-utility-bar">
      <div class="utility-search-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" placeholder="Search products..." disabled>
      </div>
      <div class="utility-right-side">
        <span class="product-counter-text">{{ collection.products_count }} Products</span>
        
        <!-- ACTIVE FILTER BUTTON -->
        <button class="utility-filter-btn" onclick="document.getElementById('fancyFilterDrawer').style.transform='translateX(0)'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
          FILTERS
        </button>

        <!-- ACTIVE SORT BUTTON -->
        <button class="utility-sort-dropdown" onclick="document.getElementById('fancySortDrawer').style.transform='translateX(0)'">
          NATIVE SORT 
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
      </div>
    </div>

    <div class="brand-products-grid">
      {% for product in collection.products %}
        <div class="brand-product-card">
          <a href="{{ product.url }}" class="product-card-anchor">
            
            <div class="product-image-container-wrapper">
              
              <div class="badge-stack-container">
                {% if product.compare_at_price > product.price %}
                  {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <span class="badge-discount-tag">-{{ savings }}%</span>
                {% endif %}
                <span class="badge-new-tag">NEW</span>
                {% if forloop.first %}
                  <span class="badge-best-tag">BEST</span>
                {% endif %}
              </div>

              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}" class="main-grid-img">
              {% else %}
                <img src="https://images.unsplash.com/photo-1618886614638-80e3c103d31a?auto=format&fit=crop&q=80&w=600" alt="Placeholder" class="main-grid-img">
              {% endif %}
            </div>

            <div class="product-meta-details-block">
              <span class="meta-category-subtitle">{{ collection.title | upcase }}</span>
              <h3 class="meta-product-title">{{ product.title }}</h3>
              
              <div class="figma-stars-row">
                <span class="gold-stars">★★★★☆</span>
                <span class="reviews-count-text">(142)</span>
              </div>

              <div class="meta-price-row">
                <span class="meta-price-active">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="meta-price-old">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>

          </a>
        </div>
      {% else %}
        <div class="empty-collection-fallback">
          <p>No products found in this collection. Please assign tags or add items from Admin panel.</p>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<!-- ========================================== -->
<!-- 1. FANCY FILTER DRAWER (BUSINESS BLACK STYLE) -->
<!-- ========================================== -->
<div id="fancyFilterDrawer" style="position: fixed; top: 0; right: 0; width: 85%; max-width: 400px; height: 100vh; background: #0d0d0d; border-left: 1px solid #1a1a1a; z-index: 99999; transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); padding: 30px; box-sizing: border-box; color: #fff; overflow-y: auto; font-family: -apple-system, BlinkMacSystemFont, sans-serif;">
  <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1a1a1a; padding-bottom: 15px; margin-bottom: 25px;">
    <h2 style="font-size: 16px; font-weight: 700; letter-spacing: 2px; margin: 0; text-transform: uppercase;">Filter Engine</h2>
    <span onclick="document.getElementById('fancyFilterDrawer').style.transform='translateX(100%)'" style="cursor: pointer; font-size: 20px; color: #666;">✕</span>
  </div>

  <!-- Price Range Section -->
  <div style="margin-bottom: 30px;">
    <h3 style="font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: #555; margin-bottom: 15px; font-weight: 700;">Price Range</h3>
    <div style="display: flex; align-items: center; gap: 10px;">
      <input type="number" placeholder="₹ Min" style="width: 100%; background: #000; border: 1px solid #1a1a1a; padding: 12px; color: #fff; font-size: 12px; text-align: center; border-radius: 20px;">
      <span style="color: #444; font-size: 12px;">to</span>
      <input type="number" placeholder="₹ Max" style="width: 100%; background: #000; border: 1px solid #1a1a1a; padding: 12px; color: #fff; font-size: 12px; text-align: center; border-radius: 20px;">
    </div>
  </div>

  <!-- Size Filter Section -->
  <div style="margin-bottom: 30px;">
    <h3 style="font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: #555; margin-bottom: 15px; font-weight: 700;">Select Size</h3>
    <div style="display: flex; flex-wrap: wrap; gap: 10px;">
      <span class="fancy-size-bubble" onclick="this.classList.toggle('active-size')" style="border: 1px solid #1a1a1a; padding: 8px 18px; font-size: 11px; font-weight: 700; cursor: pointer; background: #000; border-radius: 20px; transition: 0.2s;">S</span>
      <span class="fancy-size-bubble" onclick="this.classList.toggle('active-size')" style="border: 1px solid #1a1a1a; padding: 8px 18px; font-size: 11px; font-weight: 700; cursor: pointer; background: #000; border-radius: 20px; transition: 0.2s;">M</span>
      <span class="fancy-size-bubble" onclick="this.classList.toggle('active-size')" style="border: 1px solid #1a1a1a; padding: 8px 18px; font-size: 11px; font-weight: 700; cursor: pointer; background: #000; border-radius: 20px; transition: 0.2s;">L</span>
      <span class="fancy-size-bubble" onclick="this.classList.toggle('active-size')" style="border: 1px solid #1a1a1a; padding: 8px 18px; font-size: 11px; font-weight: 700; cursor: pointer; background: #000; border-radius: 20px; transition: 0.2s;">XL</span>
      <span class="fancy-size-bubble" onclick="this.classList.toggle('active-size')" style="border: 1px solid #1a1a1a; padding: 8px 18px; font-size: 11px; font-weight: 700; cursor: pointer; background: #000; border-radius: 20px; transition: 0.2s;">XXL</span>
    </div>
  </div>

  <!-- Color Filter Section -->
  <div style="margin-bottom: 40px;">
    <h3 style="font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: #555; margin-bottom: 15px; font-weight: 700;">Color Palette</h3>
    <div style="display: flex; flex-wrap: wrap; gap: 12px;">
      <span style="width: 28px; height: 28px; background: #fff; border-radius: 50%; display: inline-block; cursor: pointer; border: 1px solid #333;"></span>
      <span style="width: 28px; height: 28px; background: #000; border-radius: 50%; display: inline-block; cursor: pointer; border: 1px solid #333;"></span>
      <span style="width: 28px; height: 28px; background: #1e3a8a; border-radius: 50%; display: inline-block; cursor: pointer; border: 1px solid #111;"></span>
      <span style="width: 28px; height: 28px; background: #b45309; border-radius: 50%; display: inline-block; cursor: pointer; border: 1px solid #111;"></span>
      <span style="width: 28px; height: 28px; background: #15803d; border-radius: 50%; display: inline-block; cursor: pointer; border: 1px solid #111;"></span>
    </div>
  </div>

  <button onclick="document.getElementById('fancyFilterDrawer').style.transform='translateX(100%)'" style="background: #ffffff; color: #000000; width: 100%; border: none; padding: 14px; font-size: 12px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer; border-radius: 25px;">
    See Collection Items
  </button>
</div>

<!-- ========================================== -->
<!-- 2. FANCY SORT DRAWER (BEST SELLER / A-Z) -->
<!-- ========================================== -->
<div id="fancySortDrawer" style="position: fixed; top: 0; right: 0; width: 85%; max-width: 400px; height: 100vh; background: #0d0d0d; border-left: 1px solid #1a1a1a; z-index: 99999; transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); padding: 30px; box-sizing: border-box; color: #fff; font-family: -apple-system, BlinkMacSystemFont, sans-serif;">
  <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1a1a1a; padding-bottom: 15px; margin-bottom: 25px;">
    <h2 style="font-size: 16px; font-weight: 700; letter-spacing: 2px; margin: 0; text-transform: uppercase;">Sort Engine</h2>
    <span onclick="document.getElementById('fancySortDrawer').style.transform='translateX(100%)'" style="cursor: pointer; font-size: 20px; color: #666;">✕</span>
  </div>

  <div style="display: flex; flex-direction: column; gap: 8px;">
    <a href="?sort_by=manual" style="color: #fff; text-decoration: none; padding: 12px 15px; border-radius: 8px; font-size: 13px; font-weight: 600; background: #000; border: 1px solid #111;">✦ Featured Selection</a>
    <a href="?sort_by=best-selling" style="color: #FFB800; text-decoration: none; padding: 12px 15px; border-radius: 8px; font-size: 13px; font-weight: 700; background: #000; border: 1px solid #111;">★ Best Selling</a>
    <a href="?sort_by=title-ascending" style="color: #aaa; text-decoration: none; padding: 12px 15px; font-size: 13px;">Alphabetically, A-Z</a>
    <a href="?sort_by=title-descending" style="color: #aaa; text-decoration: none; padding: 12px 15px; font-size: 13px;">Alphabetically, Z-A</a>
    <a href="?sort_by=price-ascending" style="color: #aaa; text-decoration: none; padding: 12px 15px; font-size: 13px;">Price, Low to High</a>
    <a href="?sort_by=price-descending" style="color: #aaa; text-decoration: none; padding: 12px 15px; font-size: 13px;">Price, High to Low</a>
  </div>
</div>

<style>
  /* Base Scaffolding */
  .brand-collection-wrapper { background-color: #000000; color: #ffffff; padding: 40px 15px; min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .brand-collection-container { max-width: 1200px; margin: 0 auto; }
  
  /* Header Section */
  .collection-intro-header { text-align: left; margin-bottom: 35px; border-bottom: 1px solid #111; padding-bottom: 20px; }
  .main-collection-title { font-size: 32px; font-weight: 800; letter-spacing: 1px; margin: 0 0 5px 0; }
  .main-collection-subtitle { color: #555555; font-size: 13px; margin: 0; letter-spacing: 0.5px; }

  /* Figma Utility Filter Component */
  .figma-utility-bar { display: flex; flex-direction: column; gap: 15px; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; }
  .utility-search-box { display: flex; align-items: center; gap: 10px; background-color: #0d0d0d; border: 1px solid #1a1a1a; padding: 10px 15px; border-radius: 25px; width: 100%; max-width: 320px; }
  .utility-search-box input { background: none; border: none; color: #fff; font-size: 13px; width: 100%; outline: none; }
  
  .utility-right-side { display: flex; align-items: center; gap: 15px; width: 100%; justify-content: space-between; }
  .product-counter-text { color: #555555; font-size: 13px; font-weight: 500; }
  .utility-filter-btn, .utility-sort-dropdown { background-color: #0d0d0d; border: 1px solid #1a1a1a; color: #ffffff; font-size: 12px; font-weight: 700; padding: 10px 20px; border-radius: 25px; display: flex; align-items: center; gap: 8px; cursor: pointer; transition: 0.2s; }
  .utility-filter-btn:hover, .utility-sort-dropdown:hover { border-color: #444; background-color: #111; }

  /* Grid Architecture */
  .brand-products-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; }
  .brand-product-card { background-color: transparent; position: relative; }
  .product-card-anchor { text-decoration: none; color: inherit; display: block; }

  /* Light Round Curved Corners (Figma Request) */
  .product-image-container-wrapper { width: 100%; aspect-ratio: 3/4; border-radius: 12px; overflow: hidden; background-color: #0d0d0d; position: relative; border: 1px solid #111; }
  .main-grid-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
  .brand-product-card:hover .main-grid-img { transform: scale(1.04); }

  /* Badges Stack Style */
  .badge-stack-container { position: absolute; top: 12px; left: 12px; display: flex; flex-direction: column; gap: 6px; z-index: 3; }
  .badge-discount-tag { background-color: #000000; color: #ffffff; font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 20px; border: 1px solid #222; }
  .badge-new-tag { background-color: #ffffff; color: #000000; font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 20px; text-align: center; }
  .badge-best-tag { background-color: #FFB800; color: #000000; font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 20px; text-align: center; }

  /* Typography Details Block */
  .product-meta-details-block { padding: 12px 2px; }
  .meta-category-subtitle { font-size: 10px; color: #444444; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 4px; font-weight: 600; }
  .meta-product-title { font-size: 14px; font-weight: 700; color: #ffffff; margin: 0 0 6px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  
  /* Star Ratings */
  .figma-stars-row { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
  .gold-stars { color: #FFB800; font-size: 11px; letter-spacing: 1px; }
  .reviews-count-text { color: #444444; font-size: 11px; font-weight: 500; }

  /* Prices */
  .meta-price-row { display: flex; align-items: center; gap: 10px; }
  .meta-price-active { font-size: 15px; font-weight: 700; color: #ffffff; }
  .meta-price-old { font-size: 12px; color: #444444; text-decoration: line-through; }
  .empty-collection-fallback { grid-column: 1/-1; text-align: center; padding: 100px 0; color: #444; }

  /* Click Effect for Size Bubbles */
  .active-size { background: #ffffff !important; color: #000000 !important; }

  /* Desktop Responsiveness */
  @media (min-width: 768px) {
    .brand-products-grid { grid-template-columns: repeat(4, 1fr); gap: 25px; }
    .figma-utility-bar { flex-direction: row; align-items: center; }
    .utility-right-side { width: auto; gap: 20px; }
    .main-collection-title { font-size: 42px; }
    .product-image-container-wrapper { border-radius: 16px; }
  }
</style>

{% schema %}
{
  "name": "Collection Grid Matrix",
  "settings": []
}
{% endschema %}
