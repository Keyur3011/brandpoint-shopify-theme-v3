<div class="brand-collection-wrapper">
  <div class="brand-collection-container">
    
    <div class="collection-intro-header">
      <h1 class="main-collection-title">{{ collection.title | upcase }}</h1>
      <p class="main-collection-subtitle">Premium Indian Streetwear & Luxury Casual Fashion</p>
    </div>

    <div class="figma-utility-bar">
      <div class="utility-search-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" placeholder="Search products..." disabled>
      </div>
      <div class="utility-right-side">
        <span class="product-counter-text">{{ collection.products_count }} Products</span>
        
        <button class="utility-filter-btn" onclick="document.getElementById('fancyFilterDrawer').style.transform='translateX(0)'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
          FILTERS
        </button>
      </div>
    </div>

    {% if collection.products.size > 0 %}
      <div class="brand-products-grid">
        {% for product in collection.products %}
          <div class="brand-product-card">
            <a href="{{ product.url }}" class="product-card-anchor">
              <div class="product-image-container-wrapper">
                <div class="badge-stack-container">
                  {% if product.compare_at_price > product.price %}
                    {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                    <span class="badge-discount-tag">-{{ savings }}%</span>
                  {% endif %}
                  <span class="badge-new-tag">NEW</span>
                </div>
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}" class="main-grid-img">
                {% else %}
                  <img src="https://images.unsplash.com/photo-1618886614638-80e3c103d31a?auto=format&fit=crop&q=80&w=600" alt="Placeholder" class="main-grid-img">
                {% endif %}
              </div>
              <div class="product-meta-details-block">
                <span class="meta-category-subtitle">{{ collection.title | upcase }}</span>
                <h3 class="meta-product-title">{{ product.title }}</h3>
                <div class="figma-stars-row">
                  <span class="gold-stars">★★★★☆</span>
                  <span class="reviews-count-text">(142)</span>
                </div>
                <div class="meta-price-row">
                  <span class="meta-price-active">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="meta-price-old">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="no-products-found-box">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="1.5" style="margin-bottom: 15px;"><circle cx="12" cy="12" r="10"></circle><line x1="8" y1="12" x2="16" y2="12"></line></svg>
        <h2>No products found in this collection</h2>
        <p>Please change or clear your filters to find available streetwear items.</p>
        <a href="/collections/{{ collection.handle }}" class="error-clear-btn">Clear Filters</a>
      </div>
    {% endif %}

  </div>
</div>

<div id="fancyFilterDrawer" class="filter-drawer-overlay">
  <form id="ShopifyFilterForm" action="{{ collection.url }}" method="get" class="filter-drawer-form">
    
    <div class="drawer-header">
      <h2>Filter</h2>
      <span class="drawer-close-btn" onclick="document.getElementById('fancyFilterDrawer').style.transform='translateX(100%)'">✕</span>
    </div>

    <div class="drawer-body">
      
      <div class="filter-group-box">
        <h3 class="filter-group-title">Price</h3>
        <div class="price-inputs-container">
          <div class="price-field">
            <span>₹</span>
            <input type="number" name="filter.v.price.gte" id="Filter-Price-GTE"
              {% if collection.filters.size > 0 %}
                {% for filter in collection.filters %}
                  {% if filter.type == 'price_range' and filter.min_value.value %}
                    value="{{ filter.min_value.value | divided_by: 100 }}"
                  {% endif %}
                {% endfor %}
              {% endif %}
              placeholder="0">
          </div>
          <span class="to-separator">to</span>
          <div class="price-field">
            <span>₹</span>
            <input type="number" name="filter.v.price.lte" id="Filter-Price-LTE"
              {% if collection.filters.size > 0 %}
                {% for filter in collection.filters %}
                  {% if filter.type == 'price_range' and filter.max_value.value %}
                    value="{{ filter.max_value.value | divided_by: 100 }}"
                  {% endif %}
                {% endfor %}
              {% endif %}
              placeholder="1,299.00">
          </div>
        </div>
      </div>

      <div class="filter-group-box">
        <h3 class="filter-group-title">Size</h3>
        <div class="size-pills-grid">
          {% assign sizes = "S,M,L,XL,XXL" | split: "," %}
          {% for size in sizes %}
            {% assign tag_value = size | prepend: 'size-' %}
            {% assign is_size_active = false %}
            {% if current_tags contains tag_value %}{% assign is_size_active = true %}{% endif %}
            
            <label class="size-pill-label {% if is_size_active %}active-pill{% endif %}">
              <input type="checkbox" name="constraint" value="{{ tag_value }}" {% if is_size_active %}checked{% endif %} class="hidden-filter-checkbox">
              {{ size }}
            </label>
          {% endfor %}
        </div>
      </div>

      <div class="filter-group-box">
        <h3 class="filter-group-title">Color</h3>
        <div class="color-swatches-matrix">
          {% assign color_names = "Black,Off-White,Charcoal,Navy Blue,Olive Green,Burgundy,Mustard,Beige,Chocolate Brown,Sage Green,Rust Orange,Classic Blue,Lavender" | split: "," %}
          {% assign color_hexes = "#000000,#f5f5f0,#333333,#0a192f,#3b4d3a,#58111a,#e1ad01,#f5f5dc,#3d2314,#9c9f84,#b7410e,#0047ab,#e6e6fa" | split: "," %}
          
          {% for name in color_names %}
            {% assign idx = forloop.index0 %}
            {% assign current_hex = color_hexes[idx] %}
            {% assign color_tag = name | downcase | replace: " ", "-" | prepend: 'color-' %}
            {% assign is_color_active = false %}
            {% if current_tags contains color_tag %}{% assign is_color_active = true %}{% endif %}
            
            <label class="color-swatch-item {% if is_color_active %}active-color-border{% endif %}" title="{{ name }}">
              <input type="checkbox" name="constraint" value="{{ color_tag }}" {% if is_color_active %}checked{% endif %} class="hidden-filter-checkbox">
              <span class="color-dot-visual" style="background-color: {{ current_hex }};">
                {% if is_color_active %}
                  <span class="checkmark-tick">✓</span>
                {% endif %}
              </span>
            </label>
          {% endfor %}
        </div>
      </div>

      <div class="filter-group-box" style="border-bottom: none;">
        <h3 class="filter-group-title">Sort</h3>
        <select name="sort_by" class="drawer-sort-select">
          <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best selling</option>
          <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price, Low to High</option>
          <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price, High to Low</option>
          <option value="title-ascending" {% if collection.sort_by == 'title-ascending' %}selected{% endif %}>Alphabetically, A-Z</option>
          <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Date, New to Old</option>
        </select>
      </div>

    </div>

    <div class="drawer-bottom-actions">
      {% if current_tags.size > 0 %}
        <a href="/collections/{{ collection.handle }}" class="clear-all-link">Clear All</a>
      {% endif %}
      <button type="submit" class="apply-filters-sticky-btn">See Items</button>
    </div>

  </form>
</div>

<style>
  /* ग्लोबल रीसेट - किसी भी टाइटल या कार्ड में अंडरलाइन न आए */
  .brand-collection-wrapper, .brand-collection-wrapper *, 
  .brand-product-card a, .meta-product-title, .product-card-anchor {
    text-decoration: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
  }

  .brand-collection-wrapper { background-color: #000000; color: #ffffff; padding: 40px 15px; min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .brand-collection-container { max-width: 1200px; margin: 0 auto; }
  .collection-intro-header { text-align: left; margin-bottom: 35px; border-bottom: 1px solid #111; padding-bottom: 20px; }
  .main-collection-title { font-size: 32px; font-weight: 800; letter-spacing: 1px; margin: 0; color: #fff; }
  .main-collection-subtitle { color: #555555; font-size: 13px; margin-top: 5px; }
  
  .figma-utility-bar { display: flex; flex-direction: column; gap: 15px; justify-content: space-between; margin-bottom: 30px; }
  .utility-search-box { display: flex; align-items: center; gap: 10px; background-color: #0d0d0d; border: 1px solid #1a1a1a; padding: 10px 15px; border-radius: 25px; width: 100%; max-width: 320px; }
  .utility-search-box input { background: none; border: none; color: #fff; font-size: 13px; width: 100%; outline: none; }
  .utility-right-side { display: flex; align-items: center; gap: 15px; width: 100%; justify-content: space-between; }
  .product-counter-text { color: #555555; font-size: 13px; }
  .utility-filter-btn { background-color: #0d0d0d; border: 1px solid #1a1a1a; color: #ffffff; font-size: 12px; font-weight: 700; padding: 10px 25px; border-radius: 25px; display: flex; align-items: center; gap: 8px; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; }

  /* नो प्रोडक्ट फाउंड बॉक्स */
  .no-products-found-box { text-align: center; padding: 60px 20px; background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 16px; max-width: 500px; margin: 40px auto; }
  .no-products-found-box h2 { font-size: 18px; font-weight: 700; color: #fff; margin: 0 0 10px 0; }
  .no-products-found-box p { font-size: 13px; color: #666; margin: 0 0 20px 0; line-height: 1.5; }
  .error-clear-btn { display: inline-block; background: #fff; color: #000; font-size: 13px; font-weight: 700; padding: 12px 30px; border-radius: 25px; transition: opacity 0.2s; }
  .error-clear-btn:hover { opacity: 0.9; }

  /* प्रोडक्ट ग्रिड */
  .brand-products-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; }
  .product-image-container-wrapper { width: 100%; aspect-ratio: 3/4; border-radius: 12px; overflow: hidden; background-color: #0d0d0d; position: relative; border: 1px solid #111; }
  .main-grid-img { width: 100%; height: 100%; object-fit: cover; }
  .badge-stack-container { position: absolute; top: 12px; left: 12px; display: flex; flex-direction: column; gap: 6px; z-index: 2; }
  .badge-discount-tag { background-color: #000; color: #fff; font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 20px; border: 1px solid #222; }
  .badge-new-tag { background-color: #fff; color: #000; font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 20px; }
  .product-meta-details-block { padding: 12px 2px; text-decoration: none !important; }
  .meta-category-subtitle { font-size: 10px; color: #444; text-transform: uppercase; display: block; margin-bottom: 4px; }
  .meta-product-title { font-size: 14px; font-weight: 700; color: #ffffff !important; margin: 0 0 6px 0; text-decoration: none !important; }
  .figma-stars-row { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
  .gold-stars { color: #FFB800; font-size: 11px; }
  .reviews-count-text { color: #444; font-size: 11px; }
  .meta-price-row { display: flex; align-items: center; gap: 10px; }
  .meta-price-active { font-size: 15px; font-weight: 700; color: #fff; }
  .meta-price-old { font-size: 12px; color: #444; text-decoration: line-through !important; }

  /* फ़िल्टर ड्रावर UI */
  .filter-drawer-overlay { position: fixed; top: 0; right: 0; width: 88%; max-width: 400px; height: 100vh; background: #2b1e16; border-left: 1px solid #3d2b20; z-index: 99999; transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); color: #fff; box-shadow: -5px 0 25px rgba(0,0,0,0.5); }
  .filter-drawer-form { display: flex; flex-direction: column; height: 100%; margin: 0; padding: 0; }
  
  .drawer-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .drawer-header h2 { font-size: 20px; font-weight: 600; margin: 0; color: #fff; }
  .drawer-close-btn { cursor: pointer; font-size: 20px; color: rgba(255,255,255,0.6); padding: 5px; }

  .drawer-body { flex: 1; overflow-y: auto; padding: 20px 25px 100px 25px; }
  .filter-group-box { margin-bottom: 25px; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 25px; }
  .filter-group-title { font-size: 16px; font-weight: 500; color: #fff; margin: 0 0 15px 0; }

  /* प्राइस फ़ील्ड्स */
  .price-inputs-container { display: flex; align-items: center; gap: 12px; }
  .price-field { display: flex; align-items: center; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; padding: 10px 12px; width: 100%; }
  .price-field span { color: rgba(255,255,255,0.4); font-size: 14px; margin-right: 5px; }
  .price-field input { background: transparent; border: none; color: #fff; font-size: 14px; width: 100%; outline: none; }
  .to-separator { color: rgba(255,255,255,0.5); font-size: 14px; }

  /* साइज पिल्स */
  .size-pills-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .size-pill-label { display: inline-block; padding: 10px 22px; border-radius: 12px; font-size: 13px; font-weight: 500; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.8); cursor: pointer; transition: all 0.2s ease; user-select: none; text-align: center; }
  .size-pill-label:hover { border-color: rgba(255,255,255,0.4); }
  .hidden-filter-checkbox { display: none !important; }
  .size-pill-label.active-pill { background: #fff !important; color: #000 !important; border-color: #fff !important; font-weight: 700; }

  /* कलर स्वैचेस */
  .color-swatches-matrix { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; }
  .color-swatch-item { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; border: 2px solid transparent; transition: all 0.2s ease; background: transparent; }
  .color-dot-visual { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; border: 1px solid rgba(0,0,0,0.15); }
  .checkmark-tick { font-size: 12px; font-weight: 900; color: #fff; text-shadow: 0 1px 3px rgba(0,0,0,0.8); }
  .color-swatch-item.active-color-border { border-color: #fff; }

  /* सॉर्ट */
  .drawer-sort-select { width: 100%; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; padding: 12px; color: #fff; font-size: 14px; outline: none; cursor: pointer; }

  /* स्टिकी बॉटम बार */
  .drawer-bottom-actions { position: absolute; bottom: 0; left: 0; width: 100%; background: #2b1e16; padding: 15px 25px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 15px; box-sizing: border-box; }
  .clear-all-link { color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none !important; border-bottom: 1px solid rgba(255,255,255,0.3) !important; padding-bottom: 2px; cursor: pointer; }
  .clear-all-link:hover { color: #fff; border-color: #fff !important; }
  .apply-filters-sticky-btn { flex: 1; background: #000000; color: #ffffff; border: none; padding: 14px 20px; font-size: 14px; font-weight: 700; border-radius: 25px; cursor: pointer; text-align: center; text-transform: uppercase; letter-spacing: 1px; transition: background 0.2s; }
  .apply-filters-sticky-btn:hover { background: #111; }

  @media (min-width: 768px) {
    .brand-products-grid { grid-template-columns: repeat(4, 1fr); gap: 25px; }
    .figma-utility-bar { flex-direction: row; align-items: center; }
    .utility-right-side { width: auto; gap: 20px; }
    .product-image-container-wrapper { border-radius: 16px; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const sizePills = document.querySelectorAll('.size-pill-label');
    sizePills.forEach(pill => {
      pill.addEventListener('click', function() {
        const checkbox = this.querySelector('input[type="checkbox"]');
        if(checkbox) {
          setTimeout(() => {
            if(checkbox.checked) {
              this.classList.add('active-pill');
            } else {
              this.classList.remove('active-pill');
            }
          }, 50);
        }
      });
    });

    const colorSwatches = document.querySelectorAll('.color-swatch-item');
    colorSwatches.forEach(swatch => {
      swatch.addEventListener('click', function() {
        const checkbox = this.querySelector('input[type="checkbox"]');
        if(checkbox) {
          setTimeout(() => {
            if(checkbox.checked) {
              this.classList.add('active-color-border');
            } else {
              this.classList.remove('active-color-border');
            }
          }, 50);
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Collection Grid Matrix",
  "settings": []
}
{% endschema %}
