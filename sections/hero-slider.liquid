<!-- Brand Point Android Optimized Luxury Banner -->
<section class="elite-hero-slider-fixed">
  {%- for block in section.blocks -%}
    <div class="elite-slide-item active">
      
      <!-- Background Image with Fixed Premium Height Wrapper -->
      <div class="elite-hero-bg-wrapper-fixed">
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | img_url: '1200x' }}" alt="Brand Point Drop" class="elite-hero-img-fixed" loading="eager">
        {%- endif -%}
        <div class="elite-hero-vignette-overlay-fixed"></div>
      </div>

      <!-- Action Container - Only Single Fancy Button -->
      <div class="elite-hero-action-container-fixed">
        <a href="{{ block.settings.button_link | default: '/collections/all' }}" class="elite-fancy-boutique-btn">
          {{ block.settings.button_label | default: "SHOP NOW" }}
        </a>
      </div>

    </div>
  {%- endfor -%}
</section>

<!-- ========================================== -->
<!--       PRESTIGE MOBILE ARCHITECTURE CSS     -->
<!-- ========================================== -->
<style>
  /* Base Desktop View (Keeps it clean) */
  .elite-hero-slider-fixed {
    position: relative;
    width: 100%;
    height: 70vh; /* Perfectly proportional height for desktops */
    overflow: hidden;
    background-color: #000000;
  }

  .elite-hero-bg-wrapper-fixed {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .elite-hero-img-fixed {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top; /* Keeps the upper focus points safe */
  }

  .elite-hero-vignette-overlay-fixed {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 60%, rgba(0,0,0,0.5) 100%);
  }

  /* Bottom-Centered Action Panel */
  .elite-hero-action-container-fixed {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Ultra-Premium Fancy Thin Button Structure (No Thick White Block) */
  .elite-fancy-boutique-btn {
    display: inline-block;
    background: rgba(0, 0, 0, 0.4); /* Transparent glass effect */
    color: #ffffff;
    padding: 12px 35px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.6); /* Sleek luxury border */
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .elite-fancy-boutique-btn:hover {
    background: #ffffff;
    color: #000000;
    border-color: #ffffff;
    transform: translateY(-1px);
  }

  /* ========================================== */
  /*  CRITICAL FIX: ANDROID & IPHONE SCREEN LOCK */
  /* ========================================== */
  @media (max-width: 768px) {
    .elite-hero-slider-fixed {
      height: 58vh !important; /* Forces the image height to crop exactly where the button was in your screenshot */
    }

    .elite-hero-action-container-fixed {
      bottom: 25px; /* Safely floats just above the bottom screen cut */
    }

    .elite-fancy-boutique-btn {
      padding: 11px 30px;
      font-size: 11px;
      letter-spacing: 2.5px;
      width: auto; /* Fits beautifully without eating up screen space */
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25);
    }
  }
</style>

{% schema %}
{
  "name": "Elite Compressed Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide Background" },
        { "type": "text", "id": "button_label", "label": "Button Text", "default": "SHOP NOW" },
        { "type": "url", "id": "button_link", "label": "Button URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Elite Compressed Slider",
      "blocks": [ { "type": "slide" } ]
    }
  ]
}
{% endschema %}


