<section class="elite-hero-slider">
  {%- for block in section.blocks -%}
    <div class="elite-slide-item {% if forloop.first %}active{% endif %}">
      
      <div class="elite-hero-bg-wrapper">
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | img_url: '1800x' }}" alt="Brand Point Luxury Drops" class="elite-hero-img" loading="eager">
        {%- else -%}
          <div class="elite-hero-placeholder" style="background: #0a0a0a; height: 100vh;"></div>
        {%- endif -%}
        <div class="elite-hero-vignette-overlay"></div>
      </div>

      <div class="elite-hero-text-container">
        <h1 class="elite-hero-main-title">
          {{ block.settings.title | default: "SHOP OUR TOP PICKS" }}
        </h1>
        
        {%- if block.settings.subtext != blank -%}
          <p class="elite-hero-description">{{ block.settings.subtext }}</p>
        {%- endif -%}

        <div class="elite-hero-action-row">
          <a href="{{ block.settings.button_link | default: '/collections/all' }}" class="elite-single-hero-btn">
            {{ block.settings.button_label | default: "SHOP NOW →" }}
          </a>
        </div>
      </div>

    </div>
  {%- endfor -%}
</section>

<style>
  .elite-hero-slider {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background-color: #000000;
  }

  .elite-slide-item {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    z-index: 1;
  }

  .elite-slide-item.active {
    opacity: 1;
    z-index: 2;
  }

  .elite-hero-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .elite-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* High-end vignette to blend into dark phone UI and premium aesthetics */
  .elite-hero-vignette-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.6) 100%);
  }

  /* Central Text Blocks - Zero Line Accents */
  .elite-hero-text-container {
    position: relative;
    z-index: 10;
    text-align: center;
    color: #ffffff;
    max-width: 650px;
    padding: 0 24px;
    margin-top: 15vh; /* Shifts text gracefully downwards toward model waist-line */
  }

  .elite-hero-main-title {
    font-size: 42px;
    font-weight: 900;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin: 0 0 15px 0;
    line-height: 1.2;
    text-shadow: 0px 4px 15px rgba(0, 0, 0, 0.4);
  }

  .elite-hero-description {
    font-size: 13px;
    font-weight: 400;
    color: #cccccc;
    letter-spacing: 1.2px;
    line-height: 1.6;
    margin: 0 0 35px 0;
    text-shadow: 0px 2px 8px rgba(0, 0, 0, 0.5);
  }

  /* Structural Single Button Blueprint */
  .elite-hero-action-row {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .elite-single-hero-btn {
    display: inline-block;
    background-color: #ffffff;
    color: #000000;
    padding: 16px 45px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid #ffffff;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Premium Hover Transform Feel */
  .elite-single-hero-btn:hover {
    background-color: transparent;
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.05);
  }

  /* Perfectly Built Mobile Fine-Tuning */
  @media (max-width: 768px) {
    .elite-hero-main-title {
      font-size: 32px;
      letter-spacing: 3px;
    }
    
    .elite-hero-description {
      font-size: 11px;
      padding: 0 10px;
      margin-bottom: 25px;
    }

    .elite-single-hero-btn {
      padding: 14px 38px;
      font-size: 12px;
      letter-spacing: 2px;
      width: 85%; /* Fits perfectly on mobile view width */
    }
  }
</style>

{% schema %}
{
  "name": "Elite Luxury Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide Background" },
        { "type": "text", "id": "title", "label": "Main Title", "default": "SHOP OUR TOP PICKS" },
        { "type": "text", "id": "subtext", "label": "Sub Description" },
        { "type": "text", "id": "button_label", "label": "Button Text", "default": "SHOP NOW" },
        { "type": "url", "id": "button_link", "label": "Button URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Elite Luxury Slider",
      "blocks": [ { "type": "slide" } ]
    }
  ]
}
{% endschema %}

