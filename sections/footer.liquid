<style>
  /* General Scaffolding */
  .site-footer-premium { background-color: #000000; color: #ffffff; padding: 50px 20px 0 20px; border-top: 1px solid #111; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  
  /* Top Section Layout (Main Grid) */
  .footer-top-main-grid { max-width: 1200px; margin: 0 auto 30px auto; display: grid; grid-template-columns: 1fr; gap: 30px; }
  .footer-brand-title { font-size: 22px; font-weight: 800; letter-spacing: 2px; margin: 0 0 12px 0; }
  .footer-brand-desc { color: #555555; font-size: 13px; line-height: 1.6; max-width: 320px; margin: 0; }
  
  /* Vertical Shop Columns Style */
  .footer-col-heading { font-size: 13px; font-weight: 700; letter-spacing: 1.5px; color: #ffffff; margin: 0 0 15px 0; text-transform: uppercase; }
  .footer-links-list { list-style: none; padding: 0; margin: 0; }
  .footer-links-list li { margin-bottom: 10px; }
  .footer-links-list a { color: #888888; text-decoration: none; font-size: 13px; transition: color 0.2s; }
  .footer-links-list a:hover { color: #ffffff; }

  /* Horizontal Layout for Policies Bar (Saving Space) */
  .footer-horizontal-policies-bar { border-top: 1px solid #111; border-bottom: 1px solid #111; padding: 18px 0; margin: 20px 0; width: 100%; }
  .horizontal-links-wrapper { max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: center; gap: 12px 15px; }
  .horizontal-links-wrapper a { color: #666666; text-decoration: none; font-size: 12px; font-weight: 500; transition: color 0.2s ease; }
  .horizontal-links-wrapper a:hover { color: #ffffff; }
  .link-divider { color: #222222; font-size: 12px; font-weight: 300; }

  /* Bottom Copyright Area */
  .footer-bottom-copyright-area { padding: 25px 0; text-align: center; width: 100%; }
  .copyright-inner { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .store-copyright-text { font-size: 12px; color: #444444; margin: 0; letter-spacing: 0.5px; }
  
  /* Bottom Instagram Hover Link */
  .footer-social-original { margin: 5px 0; display: flex; justify-content: center; align-items: center; }
  .insta-original-icon-link { display: inline-block; transition: transform 0.3s ease; }
  .insta-original-icon-link:hover { transform: scale(1.18); }

  /* Two-Tone Signature Text Styles */
  .developer-signature-text { font-size: 13px; font-weight: 500; color: #888888; margin: 0; letter-spacing: 0.8px; }
  .signature-name-link { color: #ffffff; text-decoration: none; font-weight: 700; padding-bottom: 2px; border-bottom: 2px solid #ffffff; transition: all 0.25s ease-in-out; display: inline-block; }
  .signature-name-link:hover { color: #ff9900; border-bottom-color: #ff9900; transform: translateY(-1px); }

  /* Sticky 24/7 Floating Action Buttons */
  .floating-action-icons-holder { position: fixed; bottom: 25px; right: 25px; display: flex; flex-direction: column; gap: 15px; z-index: 99999; }
  .floating-icon-circle { width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ffffff; text-decoration: none; box-shadow: 0 4px 15px rgba(0,0,0,0.4); transition: transform 0.3s ease; }
  
  .instagram-float-btn { background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); }
  .whatsapp-float-btn { background-color: #25D366; }

  /* Premium Breathe Glow Animation */
  .instagram-float-btn, .whatsapp-float-btn { animation: figmaBreatheGlow 3s infinite ease-in-out; }
  .whatsapp-float-btn { animation-delay: 0.5s; }

  @keyframes figmaBreatheGlow {
    0% { transform: scale(1); box-shadow: 0 4px 10px rgba(0,0,0,0.4); }
    50% { transform: scale(1.08); box-shadow: 0 8px 25px rgba(255,255,255,0.15); }
    100% { transform: scale(1); box-shadow: 0 4px 10px rgba(0,0,0,0.4); }
  }
  .floating-icon-circle:hover { transform: scale(1.15) !important; }

  /* Desktop View Adjustments */
  @media (min-width: 768px) {
    .footer-top-main-grid { grid-template-columns: 2fr 1fr; max-width: 1000px; gap: 50px; }
    .horizontal-links-wrapper { justify-content: space-between; max-width: 900px; }
  }
</style>

