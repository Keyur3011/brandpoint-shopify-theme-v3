  /* ========================================== */
  /* MODAL DISPLAY ARCHITECTURE (THE ART PIECE) */
  /* ========================================== */
  .luxury-modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.85); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 999999; opacity: 0; pointer-events: none; transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .luxury-modal-overlay.is-active { opacity: 1; pointer-events: auto; }
  
  .luxury-modal-box { background-color: #0c0c0c; border: 1px solid #1c1c1e; width: 90%; max-width: 550px; max-height: 75vh; border-radius: 16px; position: relative; box-shadow: 0 20px 50px rgba(0,0,0,0.7); transform: translateY(30px) scale(0.96); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); overflow: hidden; }
