  .luxury-modal-close { position: absolute; top: 15px; right: 15px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: #888; width: 32px; height: 32px; border-radius: 50%; font-size: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; z-index: 10; }
  .luxury-modal-close:hover { color: #fff; background: rgba(255,255,255,0.1); transform: rotate(90deg); }
  
  .luxury-modal-scroll-content { padding: 30px 25px; overflow-y: auto; max-height: 75vh; box-sizing: border-box; }
  
  /* Inner Segment Configurations */
  .luxury-content-segment { display: none; animation: luxuryFadeIn 0.4s ease; }
  .luxury-content-segment.is-visible { display: block; }
  @keyframes luxuryFadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  
  .luxury-emoji-header { font-size: 28px; text-align: center; margin-bottom: 10px; filter: drop-shadow(0 0 10px rgba(255,255,255,0.2)); }
  .luxury-title-main { font-size: 18px; font-weight: 800; text-align: center; letter-spacing: 2px; color: #ffffff; text-transform: uppercase; margin: 0 0 15px 0; }
  .luxury-divider-line { height: 2px; width: 50px; background: linear-gradient(90deg, #ff9900, #ff5500); margin: 0 auto 25px auto; border-radius: 2px; }
  
  .luxury-title-sub { font-size: 13px; font-weight: 700; color: #ffffff; text-transform: uppercase; letter-spacing: 1px; margin: 20px 0 8px 0; display: flex; align-items: center; }
  .luxury-text-p { font-size: 13px; color: #a1a1a6; line-height: 1.6; font-weight: 400; margin: 0 0 15px 0; text-align: justify; }
  
  .luxury-card-info { background: #121214; border: 1px solid #1c1c1e; padding: 20px; border-radius: 12px; margin-top: 10px; }
  .luxury-card-info p { font-size: 13px; color: #a1a1a6; margin: 0 0 12px 0; line-height: 1.4; }
  .luxury-card-info p:last-child { margin-bottom: 0; }
  .luxury-card-info strong { color: #ffffff; font-weight: 600; display: inline-block; width: 160px; }

  /* Scrollbar Aesthetics */
  .luxury-modal-scroll-content::-webkit-scrollbar { width: 4px; }
  .luxury-modal-scroll-content::-webkit-scrollbar-track { background: transparent; }
  .luxury-modal-scroll-content::-webkit-scrollbar-thumb { background: #222; border-radius: 10px; }
  .luxury-modal-scroll-content::-webkit-scrollbar-thumb:hover { background: #444; }

  /* Screen Optimizations */
  @media (min-width: 768px) {
    .footer-top-main-grid { grid-template-columns: 2fr 1fr; max-width: 1000px; gap: 40px; }
    .horizontal-links-wrapper { justify-content: space-between; max-width: 850px; }
    .luxury-modal-scroll-content { padding: 40px; }
    .luxury-title-main { font-size: 20px; }
  }
</style>

<!-- ========================================== -->
<!-- INTELLIGENT JAVASCRIPT CONTROLLER -->
<!-- ========================================== -->
<script>
  function openLuxuryModal(segmentId) {
    const overlay = document.getElementById('luxuryModalOverlay');
    
    // Hide all internal text segments first
    document.querySelectorAll('.luxury-content-segment').forEach(segment => {
      segment.classList.remove('is-visible');
    });
    
    // Activate the targeted segment
    const targetSegment = document.getElementById(segmentId);
    if(targetSegment) {
      targetSegment.classList.add('is-visible');
    }
    
    // Trigger overlay visibility
    overlay.classList.add('is-active');
    document.body.style.overflow = 'hidden'; // Lock background scrolling
  }

  function closeLuxuryModal() {
    document.getElementById('luxuryModalOverlay').classList.remove('is-active');
    document.body.style.overflow = ''; // Restore standard scrolling
  }

  function closeLuxuryModalOutside(event) {
    if (event.target.id === 'luxuryModalOverlay') {
      closeLuxuryModal();
    }
  }

  // Escape key closing mechanism
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      closeLuxuryModal();
    }
  });
</script>

