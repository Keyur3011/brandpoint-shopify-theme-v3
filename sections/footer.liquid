<style>
  /* Footer Scaffolding */
  .site-footer-premium { background-color: #000000; color: #ffffff; padding: 60px 20px; border-top: 1px solid #111; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
  .footer-inner-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: 40px; }
  
  .footer-brand-title { font-size: 22px; font-weight: 800; letter-spacing: 2px; margin: 0 0 15px 0; }
  .footer-brand-desc { color: #666666; font-size: 14px; line-height: 1.6; max-width: 300px; margin: 0; }
  
  .footer-col-heading { font-size: 14px; font-weight: 700; letter-spacing: 1.5px; color: #ffffff; margin: 0 0 20px 0; text-transform: uppercase; }
  .footer-links-list { list-style: none; padding: 0; margin: 0; }
  .footer-links-list li { margin-bottom: 12px; }
  .footer-links-list a { color: #888888; text-decoration: none; font-size: 14px; transition: color 0.2s; }
  .footer-links-list a:hover { color: #ffffff; }

  /* Premium Floating Sticky Buttons with Light Curve/Round Shape */
  .floating-action-icons-holder { position: fixed; bottom: 25px; right: 25px; display: flex; flex-direction: column; gap: 15px; z-index: 99999; }
  
  .floating-icon-circle { width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ffffff; text-decoration: none; box-shadow: 0 4px 15px rgba(0,0,0,0.4); transition: transform 0.3s ease; }
  
  /* Instagram Smooth Pink/Purple Gradient */
  .instagram-float-btn { background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); }
  
  /* WhatsApp Clean Green Layout */
  .whatsapp-float-btn { background-color: #25D366; }

  /* Smooth Pulse/Blinking Animation (Breathe Effect) */
  .instagram-float-btn, .whatsapp-float-btn { animation: figmaBreatheGlow 3s infinite ease-in-out; }
  .whatsapp-float-btn { animation-delay: 0.5s; } /* ताकि दोनों अलग-अलग टाइम पर ब्लिंक करें और प्रीमियम लगें */

  @keyframes figmaBreatheGlow {
    0% { transform: scale(1); box-shadow: 0 4px 10px rgba(0,0,0,0.4); }
    50% { transform: scale(1.08); box-shadow: 0 8px 25px rgba(255,255,255,0.15); }
    100% { transform: scale(1); box-shadow: 0 4px 10px rgba(0,0,0,0.4); }
  }

  .floating-icon-circle:hover { transform: scale(1.15) !important; }

  /* Responsive Columns */
  @media (min-width: 768px) {
    .footer-inner-container { grid-template-columns: 1.5fr repeat(3, 1fr); gap: 30px; }
  }
</style>

