<!-- Premium Dark Footer Section -->
<footer class="site-footer">
  <div class="footer-container">
    
    <!-- Column 1: Brand Info -->
    <div class="footer-column brand-info">
      <h2 class="footer-brand-logo">BRAND POINT</h2>
      <p class="footer-tagline">Elevating everyday streetwear with premium fabrics and modern aesthetics tailored for India.</p>
      <div class="footer-socials">
        <a href="#" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.5" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="#" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="#" aria-label="Twitter">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
        </a>
      </div>
    </div>

    <!-- Column 2: Shop Links -->
    <div class="footer-column">
      <h3 class="footer-heading">SHOP</h3>
      <ul class="footer-links">
        <li><a href="/collections/shirts">Shirts</a></li>
        <li><a href="/collections/denim">Denim</a></li>
        <li><a href="/collections/t-shirts">T-Shirts</a></li>
        <li><a href="/collections/cord-set">Cord Sets</a></li>
      </ul>
    </div>

    <!-- Column 3: Support Links -->
    <div class="footer-column">
      <h3 class="footer-heading">SUPPORT</h3>
      <ul class="footer-links">
        <li><a href="/pages/contact">Contact Us</a></li>
        <li><a href="/pages/shipping">Shipping Info</a></li>
        <li><a href="/pages/returns">Track Orders / Returns</a></li>
        <li><a href="/pages/faq">FAQs</a></li>
      </ul>
    </div>

    <!-- Column 4: Company Links -->
    <div class="footer-column">
      <h3 class="footer-heading">COMPANY</h3>
      <ul class="footer-links">
        <li><a href="/pages/about-us">Our Story</a></li>
        <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
        <li><a href="/pages/terms-of-service">Terms of Service</a></li>
      </ul>
    </div>

  </div>

  <!-- Bottom Bar: Copyright & Location Note -->
  <div class="footer-bottom">
    <div class="footer-bottom-content">
      <p class="copyright-text">&copy; 2026, Brand Point. All Rights Reserved.</p>
      <p class="origin-text">Crafted with precision in Visnagar, Gujarat.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #000000;
    color: #ffffff;
    padding: 60px 20px 20px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-family: var(--font-body);
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr; /* Stacked layout on mobile for clean scrolling */
    gap: 40px 20px;
  }

  .footer-brand-logo {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 3px;
    margin: 0 0 15px 0;
  }

  .footer-tagline {
    font-size: 13px;
    color: #888888;
    line-height: 1.6;
    margin: 0 0 20px 0;
    max-width: 320px;
    font-weight: 300;
  }

  .footer-socials {
    display: flex;
    gap: 15px;
    color: #aaaaaa;
  }

  .footer-socials a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-socials a:hover {
    color: #ffffff;
  }

  .footer-heading {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0 0 20px 0;
    color: #ffffff;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 12px;
  }

  .footer-links a {
    color: #888888;
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s, padding-left 0.2s;
    display: inline-block;
  }

  .footer-links a:hover {
    color: #ffffff;
    padding-left: 4px;
  }

  /* Bottom Copyright Bar */
  .footer-bottom {
    margin-top: 60px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-bottom-content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: center;
  }

  .copyright-text {
    font-size: 11px;
    color: #555555;
    margin: 0;
    letter-spacing: 0.5px;
  }

  .origin-text {
    font-size: 10px;
    color: #444444;
    margin: 0;
    letter-spacing: 0.5px;
  }

  /* Responsive Grid for Tablets and Desktop Screens */
  @media (min-width: 768px) {
    .footer-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    .site-footer {
      padding: 80px 40px 30px 40px;
    }
    .footer-container {
      grid-template-columns: 2fr repeat(3, 1fr); /* Brand info gets more space */
    }
    .footer-bottom-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
