<!-- Brand Point Premium Moving Announcement Bar (Single Ticker) -->
<div class="brand-point-announcement-bar">
  <div class="bp-ticker-wrapper">
    <div class="bp-ticker-content">
      <span>THE NEW ERA OF STREETWEAR &nbsp;&nbsp;•&nbsp;&nbsp; WELCOME TO BRAND POINT FASHION &nbsp;&nbsp;•&nbsp;&nbsp; </span>
      <span>THE NEW ERA OF STREETWEAR &nbsp;&nbsp;•&nbsp;&nbsp; WELCOME TO BRAND POINT FASHION &nbsp;&nbsp;•&nbsp;&nbsp; </span>
      <span>THE NEW ERA OF STREETWEAR &nbsp;&nbsp;•&nbsp;&nbsp; WELCOME TO BRAND POINT FASHION &nbsp;&nbsp;•&nbsp;&nbsp; </span>
      <span>THE NEW ERA OF STREETWEAR &nbsp;&nbsp;•&nbsp;&nbsp; WELCOME TO BRAND POINT FASHION &nbsp;&nbsp;•&nbsp;&nbsp; </span>
    </div>
  </div>
</div>

<style>
  /* Fresh and Clean Layout for Top Bar */
  .brand-point-announcement-bar {
    background-color: #ffffff;
    border-bottom: 1px solid #eeeeee;
    padding: 12px 0;
    overflow: hidden;
    width: 100%;
    position: relative;
    z-index: 99999;
  }
  
  .bp-ticker-wrapper {
    display: flex;
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
  }

  .bp-ticker-content {
    display: inline-block;
    padding-left: 100%;
    animation: bpMarqueeAnimation 30s linear infinite;
  }

  .bp-ticker-content span {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 11px;
    font-weight: 800;
    color: #000000;
    letter-spacing: 2px;
    text-transform: uppercase;
    display: inline-block;
  }

  /* Infinite Scrolling Logic */
  @keyframes bpMarqueeAnimation {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-100%, 0, 0);
    }
  }

  /* Mobile Tweaks */
  @media (max-width: 749px) {
    .brand-point-announcement-bar {
      padding: 10px 0;
    }
    .bp-ticker-content span {
      font-size: 10px;
      letter-spacing: 1.5px;
    }
  }
</style>

