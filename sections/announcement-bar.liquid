<!-- Brand Point Original Rolling Announcement Bar -->
<div class="original-announcement-bar">
  <marquee behavior="scroll" direction="left" scrollamount="5">
    <span>WELCOME TO BRAND POINT FASHION</span>
  </marquee>
</div>

<style>
  .original-announcement-bar {
    background-color: #ffffff;
    color: #000000;
    padding: 10px 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-bottom: 1px solid #e5e5e5;
  }
  .original-announcement-bar marquee span {
    padding-right: 50px;
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": []
}
{% endschema %}

