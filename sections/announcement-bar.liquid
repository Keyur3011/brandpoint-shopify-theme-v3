<!-- Brand Point Elite Announcement Bar - Single Row Only -->
<div class="elite-announcement-bar-wrapper">
  <div class="elite-announcement-container">
    <p class="elite-announcement-text">
      WELCOME TO BRAND POINT FASHION
    </p>
  </div>
</div>

<!-- ========================================== -->
<!--          LUXURY BAR ARCHITECTURE           -->
<!-- ========================================== -->
<style>
  .elite-announcement-bar-wrapper {
    background-color: #ffffff; /* Pure luxury white background */
    color: #000000; /* Sharp black text */
    border-bottom: 1px solid #e5e5e5;
    padding: 10px 0;
    text-align: center;
    width: 100%;
    letter-spacing: 2px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .elite-announcement-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .elite-announcement-text {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0;
    display: inline-block;
  }

  @media (max-width: 768px) {
    .elite-announcement-bar-wrapper {
      padding: 8px 0;
    }
    .elite-announcement-text {
      font-size: 10px;
      letter-spacing: 1.5px;
    }
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}

