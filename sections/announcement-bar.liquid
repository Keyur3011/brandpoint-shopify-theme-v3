<style>
  .brandpoint-cinematic-banner {
    background: #ffffff; /* प्योर वाइट एलिगेंस */
    border-bottom: 1px solid #e5e5e5;
    overflow: hidden;
    position: relative;
    width: 100%;
    padding: 12px 0;
    display: flex;
    align-items: center;
  }

  .luxury-scroll-track {
    display: flex;
    width: max-content;
    animation: luxuryPan 25s linear infinite; /* सुपर स्मूथ इंटरनेशनल मोशन */
  }

  .luxury-scroll-content {
    display: flex;
    align-items: center;
    justify-content: space-around;
    white-space: nowrap;
    width: max-content;
  }

  /* 3D Cinematic Typography */
  .luxury-scroll-content span {
    color: #000000;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 13px;
    font-weight: 900; /* अल्ट्रा-बोल्ड इंप्रेशन */
    letter-spacing: 4px; /* हाई-एंड फैशन स्पेसिंग */
    padding: 0 30px;
    text-transform: uppercase;
    display: inline-block;
    
    /* Secret Micro-Glow Effect जो इसे रियलिस्टिक और अनकॉपीएबल बनाता है */
    text-shadow: 0px 0px 1px rgba(0,0,0,0.2), 0.5px 0.5px 0px rgba(0,0,0,0.1);
  }

  .luxury-scroll-content .luxury-divider {
    color: #cccccc;
    font-size: 16px;
    padding: 0;
    font-weight: 400;
  }

  /* जब कोई माउस ले जाए तो मोशन हल्का सा थमे (Premium UX Feature) */
  .brandpoint-cinematic-banner:hover .luxury-scroll-track {
    animation-play-state: paused;
  }

  /* Infinite Loop Mathematics */
  @keyframes luxuryPan {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }

  /* Mobile Optimization */
  @media (max-width: 768px) {
    .brandpoint-cinematic-banner { padding: 10px 0; }
    .luxury-scroll-content span { font-size: 11px; letter-spacing: 3px; padding: 0 20px; }
  }
</style>

