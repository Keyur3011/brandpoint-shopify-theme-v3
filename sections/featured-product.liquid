<!-- Brand Point Ultra-Luxury Swipeable Featured Showcase -->
<section class="luxury-featured-product-section" id="LuxuryFeatured-{{ section.id }}">
  
  <div class="featured-header-block">
    <h2 class="featured-main-title">{{ section.settings.heading_text | uppercase }}</h2>
    <p class="featured-sub-title">{{ section.settings.sub_heading_text }}</p>
    <div class="luxury-gold-accent-line"></div>
  </div>

  <!-- Swipeable Container Box -->
  <div class="luxury-swipe-slider-container">
    <div class="luxury-swipe-slider-track">
      
      {%- for block in section.blocks -%}
        {%- assign main_product = all_products[block.settings.featured_product_handle] -%}
        
        <div class="luxury-swipe-slide-item" {{ block.shopify_attributes }}>
          <div class="luxury-single-product-wrapper">
            {%- if main_product != blank -%}
              
              <!-- Clickable Product Image -->
              <a href="{{ main_product.url }}" class="luxury-product-image-link" aria-label="View {{ main_product.title }}">
                <div class="luxury-image-hover-engine">
                  <img 
                    src="{{ main_product.featured_image | img_url: '800x1000', crop: 'center' }}" 
                    alt="{{ main_product.title | escape }}" 
                    class="luxury-main-display-img"
                    loading="lazy"
                  >
                  <div class="luxury-image-overlay-glow"></div>
                </div>
              </a>

              <!-- Product Info -->
              <div class="luxury-product-info-block">
                <span class="luxury-product-vendor">{{ main_product.vendor | uppercase }}</span>
                <h3 class="luxury-product-title-text">
                  <a href="{{ main_product.url }}">{{ main_product.title }}</a>
                </h3>
                
                <div class="luxury-price-rating-row">
                  <span class="luxury-product-price-tag">{{ main_product.price | money }}</span>
                  <div class="luxury-gold-stars-stars">★★★★★</div>
                </div>

                <p class="luxury-product-description-snippet">
                  {%- if main_product.description != blank -%}
                    {{ main_product.description | strip_html | truncatewords: 22 }}
                  {%- else -%}
                    Premium quality crafted with attention to detail. Perfect for the modern wardrobe.
                  {%- endif -%}
                </p>

                <!-- Action Button -->
                <div class="luxury-action-btn-container">
                  <a href="{{ main_product.url }}" class="luxury-view-product-button-element">
                    VIEW PRODUCT
                    <span class="btn-arrow-effect">→</span>
                  </a>
                </div>
              </div>

            {%- else -%}
              <!-- Blank State Inside Slide -->
              <div class="luxury-product-placeholder-card">
                <p style="color: #666; font-size: 12px; letter-spacing: 2px; text-align:center; padding: 20px;">
                  SELECT PRODUCT {{ forloop.index }} IN CUSTOMIZER
                </p>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>

  <!-- Subtle Bottom Swipe Indicator Dots -->
  <div class="luxury-slider-dots-indicator">
    {%- for block in section.blocks -%}
      <div class="luxury-dot-node {% if forloop.first %}active-dot{% endif %}"></div>
    {%- endfor -%}
  </div>

</section>

<!-- ========================================== -->
<!-- HIGH-END LUXURY CODE STYLING ARCHITECTURE -->
<!-- ========================================== -->
<style>
  .luxury-featured-product-section {
    background-color: #000000;
    color: #ffffff;
    padding: 80px 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    overflow: hidden;
  }

  .featured-header-block {
    text-align: center;
    margin-bottom: 45px;
    padding: 0 24px;
  }

  .featured-main-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: 5px;
    color: #ffffff;
    margin: 0 0 10px 0;
  }

  .featured-sub-title {
    font-size: 12px;
    color: #666666;
    letter-spacing: 1.5px;
    margin: 0 0 18px 0;
  }

  .luxury-gold-accent-line {
    height: 1px;
    width: 50px;
    background: #D4AF37;
    margin: 0 auto;
  }

  /* Core Hardware Accelerated Swipe Engine */
  .luxury-swipe-slider-container {
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 15px;
  }

  /* Hide raw scrollbars across all modern engines */
  .luxury-swipe-slider-container::-webkit-scrollbar {
    display: none;
  }
  .luxury-swipe-slider-container {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .luxury-swipe-slider-track {
    display: flex;
    padding: 0 24px;
    gap: 30px;
  }

  .luxury-swipe-slide-item {
    flex: 0 0 calc(100% - 48px); /* Perfectly sizes one card per view matching screen edge */
    max-width: 500px;
    scroll-snap-align: center;
    box-sizing: border-box;
  }

  /* Match Screen Center balance on desktop viewports */
  @media (min-width: 769px) {
    .luxury-swipe-slider-track {
      justify-content: center;
      padding: 0;
    }
    .luxury-swipe-slide-item {
      flex: 0 0 380px;
    }
    .luxury-slider-dots-indicator {
      display: none !important;
    }
  }

  .luxury-single-product-wrapper {
    display: flex;
    flex-direction: column;
    gap: 22px;
    width: 100%;
  }

  /* Image Engine Styles */
  .luxury-product-image-link {
    display: block;
    width: 100%;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .luxury-image-hover-engine {
    position: relative;
    width: 100%;
    padding-bottom: 125%; /* 4:5 Premium Aspect Ratio */
    background-color: #111;
    overflow: hidden;
  }

  .luxury-main-display-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .luxury-product-image-link:hover .luxury-main-display-img {
    transform: scale(1.04);
  }

  .luxury-image-overlay-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, transparent 70%, rgba(0,0,0,0.2) 100%);
    pointer-events: none;
  }

  /* Info Details Styling */
  .luxury-product-info-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
    padding: 0 4px;
  }

  .luxury-product-vendor {
    font-size: 11px;
    color: #666666;
    letter-spacing: 2px;
    font-weight: 600;
  }

  .luxury-product-title-text {
    font-size: 21px;
    font-weight: 700;
    letter-spacing: 0.5px;
    margin: 0;
  }

  .luxury-product-title-text a {
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .luxury-product-title-text a:hover {
    color: #D4AF37;
  }

  .luxury-price-rating-row {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .luxury-product-price-tag {
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.5px;
  }

  .luxury-gold-stars-stars {
    color: #D4AF37;
    font-size: 11px;
    letter-spacing: 2px;
  }

  .luxury-product-description-snippet {
    font-size: 13px;
    color: #aaaaaa;
    line-height: 1.6;
    margin: 4px 0 10px 0;
  }

  /* Solid Action Button Styling */
  .luxury-action-btn-container {
    width: 100%;
  }

  .luxury-view-product-button-element {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    background-color: #ffffff;
    color: #000000;
    padding: 16px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid #ffffff;
  }

  .btn-arrow-effect {
    transition: transform 0.3s ease;
  }

  .luxury-view-product-button-element:hover {
    background-color: #000000;
    color: #ffffff;
    border-color: #ffffff;
  }

  .luxury-view-product-button-element:hover .btn-arrow-effect {
    transform: translateX(5px);
  }

  .luxury-product-placeholder-card {
    width: 100%;
    height: 380px;
    border: 1px dashed #222;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Micro Indicators Setup */
  .luxury-slider-dots-indicator {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 25px;
  }

  .luxury-dot-node {
    width: 18px;
    height: 2px;
    background-color: #333333;
    transition: background-color 0.3s ease;
  }

  .luxury-dot-node.active-dot {
    background-color: #ffffff;
  }

  @media (max-width: 480px) {
    .featured-main-title { font-size: 22px; letter-spacing: 4px; }
    .luxury-product-title-text { font-size: 19px; }
    .luxury-view-product-button-element { padding: 14px; font-size: 12px; }
  }
</style>

<!-- Micro Script to handle Dot Toggle on Touch/Swipe -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const scroller = document.querySelector('.luxury-swipe-slider-container');
    const dots = document.querySelectorAll('.luxury-dot-node');
    const slides = document.querySelectorAll('.luxury-swipe-slide-item');
    
    if(scroller && dots.length > 0) {
      scroller.addEventListener('scroll', () => {
        let scrollerWidth = scroller.clientWidth;
        let scrollLeft = scroller.scrollLeft;
        
        slides.forEach((slide, index) => {
          let slideLeft = slide.offsetLeft - scroller.offsetLeft;
          if (Math.abs(slideLeft - scrollLeft) < (scrollerWidth / 2)) {
            dots.forEach(d => d.classList.remove('active-dot'));
            if(dots[index]) dots[index].classList.add('active-dot');
          }
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Luxury Featured Swipe",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Section Heading",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "sub_heading_text",
      "label": "Sub Heading",
      "default": "Editor's picks from the latest collection"
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "Product Slide",
      "limit": 5,
      "settings": [
        {
          "type": "product",
          "id": "featured_product_handle",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxury Featured Swipe",
      "blocks": [
        { "type": "product_block" },
        { "type": "product_block" },
        { "type": "product_block" }
      ]
    }
  ]
}
{% endschema %}

